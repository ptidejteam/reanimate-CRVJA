' PAC-MAN Henrique 2025

Screen Open 1,670,847,1,Hires
Curs Off

Paper 0 : Palette $0,$00A,$FF0,$FF0,$BBB,$AAA,$BBB,$CCC

Load "pacman.abk"

Pen 1

MAP_SIZE = 30
Dim MAP(MAP_SIZE, MAP_SIZE)
Dim POINTS_MAP_X(MAP_SIZE)
Dim POINTS_MAP_Y(MAP_SIZE)
Dim COLLECTED(MAP_SIZE, MAP_SIZE)

For y = 0 To MAP_SIZE 
   For x = 0 To MAP_SIZE 
      COLLECTED(x,y) = 0
   Next
Next
Ink 3
Text 100,100,"Hello"
