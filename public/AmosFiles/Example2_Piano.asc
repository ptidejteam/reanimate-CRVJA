'REANIMATE PIANO
'BY GABRIEL C. ULLMANN, YANN-GAËL GUÉHÉNEUC, 2024
'INSPIRED BY: https://www.youtube.com/watch?v=iW-v7SpgS9Q

'Draw title and keys
'*******************
Screen Open 1,600,400,4,Hires
Curs Off

Palette $0,$FFF,$AAA,$953
Paper 3
Cls

Ink 1
Text 10,10,"ReAnimate(d) Piano"
Text 10,30,"By Gabriel C. Ullmann, 2024"

P_DRAWKEYS[-1]


' Wait for a key, draw the keyboard, play the sound
' *************************************************
Do
   Wait Key
   For I=0 To 10
      If Key State($10+I)
         P_DRAWKEYS[I]
         While Key State($10+I)
            Play 37+I,1
	     Wend
         P_DRAWKEYS[-1]
      End If
   Next I
Loop



Procedure P_DRAWKEYS[PRESSEDKEYNUMBER]
   ' White key positions
   ' *******************
   XW=70
   YW=70
   WW=50
   HW=100

   ' Black key positions
   ' *******************
   XB = XW + WW
   YB = 70
   WB = 30
   HB = 60

   ' Draw keys
   ' *********
   For I=0 To 5
      ' Draw white keys
      ' ***************
      If PRESSEDKEYNUMBER=2*I
         Ink 2
      Else 
         Ink 1
      End If 
      Bar XW+(I*(WB+WW)),YW To XW+((WB+WW)*I+WW),YW+HW

      ' Draw black keys
      ' ***************
      ' If last iteration, do not draw a black key
      ' ******************************************
      If I<>5
         If PRESSEDKEYNUMBER=2*I+1
            Ink 2
         Else
            Ink 0
         End If
         Bar XB+((WB+WW)*I),YB To XB+((WB+WW)*I+WB+WW),YB+HB
      End If
   Next I
End Proc
End