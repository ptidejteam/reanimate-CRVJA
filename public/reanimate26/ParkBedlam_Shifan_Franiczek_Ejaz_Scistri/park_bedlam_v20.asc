''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''
'                 Park Bedlam - turn-based park war              '
''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''

' By Al Shifan, Aleks Franiczek, Sikandar Ejaz and Luca Scistri
' Licensed under GPLv3 and above

' 1-4 pick unit, IJKL move, SPACE end/advance, ESC back
Screen Open 0,790,712,8,Hires
Curs Off : Flash Off
Palette $121,$5C4,$172,$05B,$986,$F40,$4AF,$EEE, $999
Cls 0

Load "AleksBank.abk"
Load "Cat.abk"
Load "DuckSquirrel.abk"
Load "Pigeon.abk"
Load "Raccoon.abk"

COLS=24 : ROWS=30 : TS=20 : OX=10 : OY=30

' MODE: 0 title, 5 story, 4 instructions, 1 pick, 2 walk, 3 game over
MODE=0-1
TEAM=0
SEL=0
SELX=0 : SELY=0 : SELR=0
SHOWR=0
MV=0
GOVER=0
WTEAM=0
PICKN=0-100
MK=0 : BK=0
MWINS=0 : BWINS=0
MSG$="click the game, then space"
DICE$=""
SCORE$=""
STORY$="park is tense"
KING$=""
SQH$=""
WM$="" : WB$="" : KL$=""
' each squad slot has a ready-copy (green) and a done-copy (grey), only one shows
R1$="" : R2$="" : R3X$="" : R4$=""
D1$="" : D2$="" : D3X$="" : D4$=""
X1$="" : X2$="" : X3X$="" : X4$=""
ENS$=""

NCX=0 : NCY=0 : MOVEDC=0 : NMODE=0 : OK=0
TX=0 : TY=0 : TAL=0
TANG=0
TX1=0 : TY1=0 : TX2=0 : TY2=0 : TX3=0 : TY3=0

PUP=0 : PDN=0 : PLT=0 : PRT=0
PSPC=0 : PESC=0
P1=0 : P2=0 : P3=0 : P4=0

Global COLS,ROWS,TS,OX,OY,MODE,TEAM,SEL,SELX,SELY,SELR,SHOWR,MV,GOVER,WTEAM,PICKN,MK,BK,MWINS,BWINS,MSG$,DICE$,SCORE$,STORY$,KING$,SQH$,WM$,WB$,KL$,R1$,R2$,R3X$,R4$,D1$,D2$,D3X$,D4$,X1$,X2$,X3X$,X4$,ENS$

' OB: 0 grass, 1 tree, 2 water, 3 dirt mound (1-3 block walking)
Dim OB(24,30)
' units 0-9. UTM 0 mammal, 1 bird, 2 human. UBUF -1 debuff / 0 / 1 buff
Dim UX(12),UY(12),UTM(12),UTY(12),UAL(12),UAC(12),UBUF(12)
' two food items
Dim FDX(3),FDY(3),FDA(3)

Procedure MAKE_HUD
   ' --- right panel: structured stats only, left margin x525 ---
   ' king name above the headshot box, quip just under it
   Ink 7
   Text 525,34,KING$
   Ink 2
   Text 525,196,STORY$
   ' squad: green=ready, grey=done, red=dead (one per row)
   Ink 5
   Text 525,240,SQH$
   Ink 6
   Text 525,268,R1$
   Text 525,294,R2$
   Text 525,320,R3X$
   Text 525,346,R4$
   Ink 4
   Text 527,268,D1$
   Text 527,294,D2$
   Text 527,320,D3X$
   Text 527,346,D4$
   Ink 5
   Text 529,268,X1$
   Text 529,294,X2$
   Text 529,320,X3X$
   Text 529,346,X4$
   ' score block lower on the panel
   Ink 5
   Text 525,648,SCORE$
   Ink 2
   Text 525,674,ENS$
   ' --- bottom-left: prompt + dice readout ---
   Ink 7
   Text 233,8,MSG$
   Ink 6
   Text 12,672,DICE$
   Ink 7
   Text 505,415,"B"
   Text 505,455,"M"
   Text 505,495,"S"
   Text 505,535,"L"
   Turbo Draw 580,160 To 620,120,7,-1
   Turbo Draw 610,124 To 620,120,7,-1
   Turbo Draw 618,130 To 620,120,7,-1
   Turbo Draw 630,120 To 670,160,7,-1
   Turbo Draw 655,157 To 670,160,7,-1
   Turbo Draw 668,150 To 670,160,7,-1
   Turbo Draw 660,165 To 590,165,7,-1
   Turbo Draw 600,160 To 590,165,7,-1
   Turbo Draw 600,170 To 590,165,7,-1
   Ink 6
   Text 570,82,"S"
   Text 620,8,"B"
   Text 675,42,"M"
   Text 620,4,"L"
End Proc

Procedure DRAW_PANEL
   ' headshot box, coloured for whoever's turn it is
   OFFSCREEN = 0-200
   If TEAM=1
      KING$="GAEL"
      Sprite 1, 540, 60, 10
      Sprite 2,OFFSCREEN,OFFSCREEN,20
   Else
      KING$="YANN"
      Sprite 2, 540, 60, 20
      Sprite 1,OFFSCREEN,OFFSCREEN,10
   End If
   BASE=TEAM*4
   For K=0 To 3
      IDX=BASE+K
      QTM=UTM(IDX)
      QTY=UTY(IDX)
      QAL=UAL(IDX)
      QAC=UAC(IDX)
      QBF=UBUF(IDX)
      NM$="?"
      If QTM=0
         If QTY=1
            NM$="RACOON"
         End If
         If QTY=2
            NM$="CAT"
         End If
         If QTY=3
            NM$="SQURL"
         End If
         If QTY=4
            NM$="YANN"
         End If
      End If
      If QTM=1
         If QTY=1
            NM$="GOOSE"
         End If
         If QTY=2
            NM$="DUCK"
         End If
         If QTY=3
            NM$="PIGEON"
         End If
         If QTY=4
            NM$="GAEL"
         End If
      End If
      BUF$=""
      If QBF=1
         BUF$=" +1"
      End If
      If QBF<0
         BUF$=" -1"
      End If
      UNN=K+1
      ' one of three rows shows per unit: green ready, grey done, red dead
      GRN$=""
      GRY$=""
      RED$=""
      If QAL=0
         RED$=UNN+" "+NM$+" DEAD"
      Else
         If QAC=1
            GRY$=UNN+" "+NM$+" DONE"
         Else
            GRN$=UNN+" "+NM$+" RDY"+BUF$
         End If
      End If
      If K=0
         R1$=GRN$ : D1$=GRY$ : X1$=RED$
      End If
      If K=1
         R2$=GRN$ : D2$=GRY$ : X2$=RED$
      End If
      If K=2
         R3X$=GRN$ : D3X$=GRY$ : X3X$=RED$
      End If
      If K=3
         R4$=GRN$ : D4$=GRY$ : X4$=RED$
      End If
   Next
   ECNT=0
   For I=0 To 7
      QALE=UAL(I)
      QTME=UTM(I)
      If QALE=1
         If QTME<>TEAM
            If QTME<2
               Add ECNT,1
            End If
         End If
      End If
   Next
   ENS$="ENEMY LEFT "+ECNT
   DRAW_BARS_PANEL
   DRAW_SPRITE_PANEL
End Proc

Procedure BLANK_HUD
   MSG$="" : DICE$="" : STORY$="" : SCORE$="" : ENS$="" : KING$="" : SQH$=""
   R1$="" : R2$="" : R3X$="" : R4$=""
   D1$="" : D2$="" : D3X$="" : D4$=""
   X1$="" : X2$="" : X3X$="" : X4$=""
   WM$="" : WB$="" : KL$=""
End Proc

Procedure DRAW_WINS
   Ink 5
   Text 150,70,"THE SCOREBOARD"
   Ink 7
   If WTEAM=0
      Text 90,140,"MAMMALS TAKE THE PARK"
   Else
      Text 110,140,"BIRDS TAKE THE PARK"
   End If
   Ink 6
   Text 180,210,"MATCH WINS"
   Ink 5
   WM$="MAMMALS  "+MWINS
   Text 160,350,WM$
   Ink 7
   WB$="BIRDS    "+BWINS
   Text 160,385,WB$
   Ink 2
   KL$="last fight kills  M "+MK+"  B "+BK
   Text 90,455,KL$
   Ink 6
   Text 100,530,"== SPACE FOR THE TITLE =="
End Proc

Procedure DRAW_TITLE
   Ink 5
   Text 315,230,"PARK BEDLAM"
   Ink 2
   Text 190,265,"A War for the Scraps of a Park"
   Ink 6
   Text 200,410,"== PRESS SPACE TO CONTINUE =="
   Ink 7
   Text 220,580,"== MADE BY BIRDS OF PREY =="
End Proc

Procedure DRAW_STORY
   Ink 5
   Text 280,45,"REANIMATE PARK..."
   Ink 7
   Text 205,90,"Once a haven where Birds and"
   Text 230,113,"Mammals lived in harmony."
   Ink 6
   Text 210,150,"Then came a cruel invention:"
   Ink 5
   Text 240,178,"ANIMAL-PROOF TRASH CANS"
   Ink 7
   Text 205,215,"Food scraps grew scarce, and"
   Text 210,238,"the critters grew desperate."
   Ink 2
   Text 205,278,"Yann the Raccoon and Gael the"
   Text 230,301,"Goose have called for WAR!"
   Sprite 30,630,405,20
   Sprite 31,630,455,10
   Ink 7
   Text 285,341,"Birds vs Mammals..."
   Ink 5
   Text 280,395,"WHO WILL YOU SUPPORT"
   Ink 6
   Text 210,455,"== SPACE TO READ THE RULES =="
End Proc

Procedure DRAW_INSTR
   Ink 5
   Text 300,45,"HOW TO PLAY"
   Ink 6
   Text 170,90,"1-4 selects corresponding animal."
   Text 185,113,"IJKL moves it - SPACE ends turn."
   Text 225,136,"Approach a foe to fight."
   Ink 7
   Text 185,176,"RACCOON + GOOSE = Big and Tough"
   Text 180,199,"CAT + DUCK = Medium and Balanced"
   Text 175,222,"SQUIRREL + PIGEON = Small and Fast"
   Ink 2
   Text 190,262,"Big > Med; Med > Sml; Sml > Big."
   Text 150,285,"Attack rolls: Strong 3+ Even 4+ Weak 5+"
   Text 190,310,"LEADER has 50/50 chance win/loss."
   Ink 5 
   Text 200,348,"Kill the LEADER and you win..."
   Text 225,371,"OR wipe their army to win."
   Ink 6
   Text 190,411,"FOOD (Red) +1 to unit next fight."
   Text 185,435,"HUMAN -1 OR +1 to unit next fight."
   Ink 5
   Text 200,455,"HIT SPACE TO BEGIN BATTLE"
  
End Proc

Procedure INIT_GAME
   TEAM=0
   SEL=0
   SELX=0 : SELY=0 : SELR=0
   SHOWR=0
   MV=0
   GOVER=0
   WTEAM=0
   MK=0 : BK=0

   For Y=0 To ROWS-1
      For X=0 To COLS-1
         OB(X,Y)=0
      Next
   Next
   ' random pond (block of water) somewhere left-of-centre
   PWX=2+Rnd(6)
   PWY=10+Rnd(4)
   For Y=PWY To PWY+3
      For X=PWX To PWX+3
         OB(X,Y)=2
      Next
   Next
   ' random water patch right-of-centre
   QWX=15+Rnd(5)
   QWY=16+Rnd(5)
   For Y=QWY To QWY+2
      For X=QWX To QWX+2
         OB(X,Y)=2
      Next
   Next
   ' scatter trees in the middle band (rows 6-23, away from spawns)
   For T=0 To 9
      TXR=1+Rnd(21)
      TYR=6+Rnd(17)
      If OB(TXR,TYR)=0
         OB(TXR,TYR)=1
      End If
   Next
   ' scatter garbage bins
   For T=0 To 5
      DXR=1+Rnd(21)
      DYR=7+Rnd(15)
      If OB(DXR,DYR)=0
         OB(DXR,DYR)=3
      End If
   Next

   ' --- mammals (south): raccoon cat squirrel YANN ---
   UX(0)=8 : UY(0)=26 : UTY(0)=1
   UX(1)=12 : UY(1)=27 : UTY(1)=2
   UX(2)=16 : UY(2)=26 : UTY(2)=3
   UX(3)=12 : UY(3)=28 : UTY(3)=4
   For I=0 To 3
      UTM(I)=0
   Next
   ' --- birds (north): goose duck pigeon GAEL ---
   UX(4)=8 : UY(4)=3 : UTY(4)=1
   UX(5)=12 : UY(5)=2 : UTY(5)=2
   UX(6)=16 : UY(6)=3 : UTY(6)=3
   UX(7)=12 : UY(7)=1 : UTY(7)=4
   For I=4 To 7
      UTM(I)=1
   Next

   For I=0 To 7
      UAL(I)=1
      UAC(I)=0
      UBUF(I)=0
   Next

   ' --- humans (neutral, mid-map, random-ish) ---
   For I=8 To 9
      HXX=3+Rnd(17)
      HYY=8+Rnd(13)
      BLK=0
      If OB(HXX,HYY)>0
         BLK=1
      End If
      If BLK=1
         HXX=7+4*(I-8)
         HYY=9
      End If
      UX(I)=HXX
      UY(I)=HYY
      UTM(I)=2
      UTY(I)=5
      UAL(I)=1
      UAC(I)=0
      UBUF(I)=0
   Next

   ' --- food items (mid-map) ---
   For F=0 To 1
      FX2=3+Rnd(17)
      FY2=8+Rnd(13)
      BLKF=0
      If OB(FX2,FY2)>0
         BLKF=1
      End If
      If BLKF=1
         FX2=6+F*6
         FY2=11
      End If
      FDX(F)=FX2
      FDY(F)=FY2
      FDA(F)=1
   Next
End Proc

Procedure DRAW_BOARD
   For Y=0 To ROWS-1
      For X=0 To COLS-1
         Ink 1
         If OB(X,Y)=1
            Ink 2
         End If
         If OB(X,Y)=2
            Ink 3
         End If
         If OB(X,Y)=3
            Ink 4
         End If
         If SHOWR=1
            If OB(X,Y)=0
               If X>=SELX-SELR
                  If X<=SELX+SELR
                     If Y>=SELY-SELR
                        If Y<=SELY+SELR
                           DISTANCE=0
                           If X<SELX
                              DISTANCE=SELX-X
                           Else
                              DISTANCE=X-SELX
                           End If
                           If Y<SELY
                              DISTANCE=DISTANCE+SELY-Y
                           Else
                              DISTANCE=DISTANCE+Y-SELY
                           End If
                           If DISTANCE<=SELR
                              Ink 6
                           End If
                        End If
                     End If
                  End If
               End If
            End If
         End If
         FZ=0
         For F=0 To 1
            QFA=FDA(F)
            If QFA=1
               QFX=FDX(F)
               QFY=FDY(F)
               If QFX=X
                  If QFY=Y
                     FZ=1
                  End If
               End If
            End If
         Next
         If FZ=1
            Ink 5
         End If
         PX=OX+X*TS
         PY=OY+Y*TS
         Bar PX+1,PY+1 To PX+TS-1,PY+TS-1
      Next
   Next
End Proc

Procedure DRAW_UNITS
   For I=0 To 9
      BAL=UAL(I)
      If BAL=1
         BX=UX(I)
         BY=UY(I)
         BTM=UTM(I)
         BTC=UTY(I)
         X=OX+BX*TS+2
         Y=OY+BY*TS+2
         ID=I
         If BTM=0
            If BTC=2
               Sprite 3,X,Y,12
            End If
            If BTC=3
               Sprite 4,X,Y,15
            End If
            If BTC=4
               Sprite 5,X,Y,8
            End If
            If BTC=1
               Sprite 6,X,Y,7
            End If
         End If
         If BTM=1
            If BTC=2
               Sprite 7,X,Y,14
            End If
            If BTC=3
               Sprite 8,X,Y,18
            End If
            If BTC=4
               Sprite 9,X,Y,3
            End If
            If BTC=1
               Sprite 10,X,Y,0
            End If
         End If
         If BTM=2
            If I=8
               Sprite 11,X,Y,4
            End If
            If I=9
               Sprite 12,X,Y,4
            End If
         End If
      End If
   Next
End Proc

Procedure MOVE_HUMANS
   For I=8 To 9
      QALM=UAL(I)
      If QALM=1
         For S=0 To 4
            HX2=UX(I)
            HY2=UY(I)
            DIR=Rnd(3)
            NHX=HX2
            NHY=HY2
            If DIR=0
               NHY=HY2-1
            End If
            If DIR=1
               NHY=HY2+1
            End If
            If DIR=2
               NHX=HX2-1
            End If
            If DIR=3
               NHX=HX2+1
            End If
            OKH=1
            If NHX<0
               OKH=0
            End If
            If NHX>COLS-1
               OKH=0
            End If
            If NHY<0
               OKH=0
            End If
            If NHY>ROWS-1
               OKH=0
            End If
            If OKH=1
               If OB(NHX,NHY)>0
                  OKH=0
               End If
            End If
            For J=0 To 9
               TALJ=UAL(J)
               TXJ=UX(J)
               TYJ=UY(J)
               If TALJ=1
                  If TXJ=NHX
                     If TYJ=NHY
                        OKH=0
                     End If
                  End If
               End If
            Next
            If OKH=1
               Blitter Clear 0,0,OX+HX2*TS,OY+HY2*TS To OX+HX2*TS+20,OY+HY2*TS+20
               UX(I)=NHX
               UY(I)=NHY
            End If
         Next
      End If
   Next
End Proc


Procedure DRAW_SPRITE_PANEL
   Sprite 14,555,405,19
   Sprite 15,555,468,11
   Sprite 16,555,528,16
   Sprite 17,555,585,20
   Sprite 13,650,405,9
   Sprite 18,650,465,13
   Sprite 19,640,523,17
   Sprite 20,650,585,10
End Proc

Procedure DRAW_BARS_PANEL
   IDX=TEAM*4+PICKN
   For I=0 To 3
      X1=530
      X2=X1+80
      Ink 1
      Y1=400+60*I
      Y2=Y1+45
      If I=IDX
         Ink 6
      End If
      QAC=UAC(I)
      If QAC=1
          Ink 4
      End If
      QAL=UAL(I)
      If QAL=0
          Ink 5
      End If
      Bar X1,Y1 To X2,Y2
   Next
   For J=4 To 7
      X1=530+100
      X2=X1+80
      Ink 1
      Y1=160+60*J
      Y2=Y1+45
      If J=IDX
         Ink 6
      End If
      QAC=UAC(J)
      If QAC=1
          Ink 4
      End If
      QAL=UAL(J)
      If QAL=0
          Ink 5
      End If
      Bar X1,Y1 To X2,Y2
   Next
End Proc

Procedure TRY_PICK
   IDX=TEAM*4+PICKN
   QAL=UAL(IDX)
   QAC=UAC(IDX)
   If QAL=0
      MSG$="THAT ONE IS GONE - PICK ANOTHER"
   End If
   If QAL=1
      If QAC=1
         MSG$="ALREADY MOVED - PICK ANOTHER"
      End If
      If QAC=0
         SEL=IDX
         SELX=UX(IDX)
         SELY=UY(IDX)
         QTC=UTY(IDX)
         MV=3
         If QTC=2
            MV=4
         End If
         If QTC=3
            MV=5
         End If
         If QTC=4
            MV=4
         End If
         SELR=MV
         SHOWR=1
         DRAW_BOARD
         DRAW_UNITS
         DRAW_BARS_PANEL
         DRAW_SPRITE_PANEL
         UN=PICKN+1
         MSG$="UNIT "+UN+" - MOVES "+MV
         MODE=2
      End If
   End If
End Proc

Procedure FINISH_UNIT
   UAC(SEL)=1
   FOUGHT=0
   DI2=0-1
   FX=UX(SEL)
   FY=UY(SEL)
   For I=0 To 7
      QAL3=UAL(I)
      QTM3=UTM(I)
      QX=UX(I)
      QY=UY(I)
      If QAL3=1
         If QTM3<>TEAM
            If QTM3<2
               If QX>=FX-1
                  If QX<=FX+1
                     If QY>=FY-1
                        If QY<=FY+1
                           DI2=I
                        End If
                     End If
                  End If
               End If
            End If
         End If
      End If
   Next

   If DI2>=0
      FOUGHT=1
      ACLS=UTY(SEL)
      DCLS=UTY(DI2)
      AC$="BIG"
      If ACLS=2
         AC$="MED"
      End If
      If ACLS=3
         AC$="SML"
      End If
      If ACLS=4
         AC$="KING"
      End If
      TH=4
      AV$="even odds"
      LEAD=0
      If ACLS=4
         LEAD=1
      End If
      If DCLS=4
         LEAD=1
      End If
      If LEAD=1
         AV$="50-50"
      End If
      If LEAD=0
         If ACLS=1
            If DCLS=2
               TH=3
               AV$="Stronger"
            End If
            If DCLS=3
               TH=5
               AV$="Weaker"
            End If
         End If
         If ACLS=2
            If DCLS=3
               TH=3
               AV$="Stronger"
            End If
            If DCLS=1
               TH=5
               AV$="Weaker"
            End If
         End If
         If ACLS=3
            If DCLS=1
               TH=3
               AV$="Stronger"
            End If
            If DCLS=2
               TH=5
               AV$="Weaker"
            End If
         End If
      End If

      ROLL=Rnd(5)+1
      QBUF=UBUF(SEL)
      If QBUF<>0
         ROLL=ROLL+QBUF
         UBUF(SEL)=0
         If QBUF=1
            AV$=AV$+" +food"
         End If
         If QBUF<0
            AV$=AV$+" -shoo"
         End If
      End If

      LOSER=SEL
      WINR=DI2
      RS$="LOSE"
      If ROLL>=TH
         LOSER=DI2
         WINR=SEL
         RS$="WIN"
         Play 61,1
      Else
         LOSER=SEL
         WINR=DI2
         RS$="LOSE"
         Play 25,1
      End If
      ' plain readout: rolled X, needed Y -> result
      DICE$="Rolled "+ROLL+" needed "+TH+" - YOU "+RS$+" ("+AV$+")"

      UAL(LOSER)=0
      LX=UX(LOSER)
      LY=UY(LOSER)
      Blitter Clear 0,0,OX+LX*TS,OY+LY*TS To OX+LX*TS+20,OY+LY*TS+20
      LTM=UTM(LOSER)
      LTY=UTY(LOSER)
      If LTM=0
         Add BK,1
      Else
         Add MK,1
      End If
      SCORE$="KILLS M "+MK+" B "+BK

      WTM=UTM(WINR)
      WTY=UTY(WINR)
      If WTM=0
         If WTY=1
            STORY$="racoon: HEEARRGHNMNN!"
         End If
         If WTY=2
            STORY$="cat: HISSSS!"
         End If
         If WTY=3
            STORY$="squirrel: CHRRRR!"
         End If
         If WTY=4
            STORY$="Yann: 'Tis mine TRASH, peasant!"
         End If
      End If
      If WTM=1
         If WTY=1
            STORY$="goose: HONK!"
         End If
         If WTY=2
            STORY$="duck: QUACK!"
         End If
         If WTY=3
            STORY$="pigeon: cooooooo"
         End If
         If WTY=4
            STORY$="Gael: I'ma tan yer furry hide!"
         End If
      End If

      If LTY=4
         GOVER=1
         WTEAM=1-LTM
         If WTEAM=0
            Add MWINS,1
         Else
            Add BWINS,1
         End If
      End If
      If LTY<4
         CNT=0
         For I=0 To 7
            QAL2=UAL(I)
            QTM2=UTM(I)
            QTY2=UTY(I)
            If QAL2=1
               If QTM2=LTM
                  If QTY2<4
                     Add CNT,1
                  End If
               End If
            End If
         Next
         If CNT=0
            GOVER=1
            WTEAM=1-LTM
            If WTEAM=0
               Add MWINS,1
            Else
               Add BWINS,1
            End If
         End If
      End If
   End If

   ' --- human encounter, if we are still standing ---
   SAL=UAL(SEL)
   If SAL=1
      If GOVER=0
         HUM=0-1
         HFX=UX(SEL)
         HFY=UY(SEL)
         For I=8 To 9
            QALH=UAL(I)
            If QALH=1
               QXH=UX(I)
               QYH=UY(I)
               If QXH>=HFX-1
                  If QXH<=HFX+1
                     If QYH>=HFY-1
                        If QYH<=HFY+1
                           HUM=I
                        End If
                     End If
                  End If
               End If
            End If
         Next
         If HUM>=0
            HR=Rnd(1)
            If HR=1
               UBUF(SEL)=1
               DICE$="HUMAN drops a snack - +1"
            End If
            If HR=0
               UBUF(SEL)=0-1
               DICE$="HUMAN shoos you - -1"
            End If
         End If
      End If
   End If

   SHOWR=0
   DRAW_BOARD
   DRAW_UNITS
   If GOVER=0
      LEFTC=0
      For I=0 To 7
         QAL4=UAL(I)
         QTM4=UTM(I)
         QAC4=UAC(I)
         If QAL4=1
            If QTM4=TEAM
               If QAC4=0
                  Add LEFTC,1
               End If
            End If
         End If
      Next
      If LEFTC=0
         TEAM=1-TEAM
         PICKN=0-100
         For I=0 To 7
            UAC(I)=0
         Next
         MOVE_HUMANS
         DRAW_BOARD
         DRAW_UNITS
         If TEAM=0
            MSG$="TURN OVER - MAMMALS GO 1-4"
         Else
            MSG$="TURN OVER - BIRDS GO 1-4"
         End If
         If FOUGHT=0
            R3=Rnd(5)
            If R3=0
               STORY$="A jogger moves away."
            End If
            If R3=1
               STORY$="Wind's howling."
            End If
            If R3=2
               STORY$="Humans bicker."
            End If
            If R3=3
               STORY$="The pond ripples."
            End If
            If R3=4
               STORY$="A dog howls."
            End If
            If R3=5
               STORY$="Rain falls."
            End If
         End If
      Else
         If TEAM=0
            MSG$="MAMMALS GO - PICK 1-4"
         Else
            MSG$="BIRDS GO - PICK 1-4"
         End If
      End If
   End If
   DRAW_PANEL
End Proc

Do
   If MODE=-1
      DRAW_TITLE
      MODE=0
   End If

   ' ============ TITLE: spin the triangle ============
   If MODE=0
      TANG=TANG+3
      If TANG>359
         TANG=0
      End If
      TX1=390+70*Cos(TANG)
      TY1=110+70*Sin(TANG)
      TX2=390+70*Cos(TANG+120)
      TY2=110+70*Sin(TANG+120)
      TX3=390+70*Cos(TANG+240)
      TY3=110+70*Sin(TANG+240)
      Turbo Draw TX1,TY1 To TX2,TY2,5,-1
      Turbo Draw TX2,TY2 To TX3,TY3,7,-1
      Turbo Draw TX3,TY3 To TX1,TY1,6,-1
   End If

   ' ============ WALK THE SELECTED UNIT ============
   If MODE=2
      MOVEDC=0
      NCX=SELX
      NCY=SELY
      If Key State($17)
         Add PUP,1
         If PUP=1
            NCY=SELY-1
            MOVEDC=1
         End If
         If PUP>7
            PUP=0
         End If
      Else
         PUP=0
      End If
      If Key State($25)
         Add PDN,1
         If PDN=1
            NCY=SELY+1
            MOVEDC=1
         End If
         If PDN>7
            PDN=0
         End If
      Else
         PDN=0
      End If
      If Key State($24)
         Add PLT,1
         If PLT=1
            NCX=SELX-1
            MOVEDC=1
         End If
         If PLT>7
            PLT=0
         End If
      Else
         PLT=0
      End If
      If Key State($26)
         Add PRT,1
         If PRT=1
            NCX=SELX+1
            MOVEDC=1
         End If
         If PRT>7
            PRT=0
         End If
      Else
         PRT=0
      End If
      If MOVEDC=1
         OK=1
         If NCX<0
            OK=0
         End If
         If NCX>COLS-1
            OK=0
         End If
         If NCY<0
            OK=0
         End If
         If NCY>ROWS-1
            OK=0
         End If
         If OK=1
            If OB(NCX,NCY)>0
               OK=0
            End If
         End If
         For I=0 To 9
            TAL=UAL(I)
            TX=UX(I)
            TY=UY(I)
            If TAL=1
               If TX=NCX
                  If TY=NCY
                     OK=0
                  End If
               End If
            End If
         Next
         If OK=1
            Blitter Clear 0,0,OX+SELX*TS,OY+SELY*TS To OX+SELX*TS+20,OY+SELY*TS+20
            NOTE = 37+Rnd(6)
            Play NOTE,1
            UX(SEL)=NCX
            UY(SEL)=NCY
            SELX=NCX
            SELY=NCY
            MV=MV-1
            For I=0 To 1
               QFAL=FDA(I)
               If QFAL=1
                  QFX2=FDX(I)
                  QFY2=FDY(I)
                  If QFX2=NCX
                     If QFY2=NCY
                        FDA(I)=0
                        UBUF(SEL)=1
                        DICE$="Ate FOOD - +1 next fight"
                     End If
                  End If
               End If
            Next
            DRAW_UNITS
            If MV>0
               SELR=MV
               DRAW_BOARD
               DRAW_UNITS
               MSG$="MOVES LEFT "+MV
            Else
               FINISH_UNIT
               If GOVER=1
                  PICKN=0-100
                  If WTEAM=0
                     MSG$="MAMMALS WIN - SPACE = MENU"
                     STORY$="Yann: WE WON!"
                  Else
                     MSG$="BIRDS WIN - SPACE = MENU"
                     STORY$="Gael: WE WON!"
                  End If
                  MODE=3
               Else
                  MODE=1
               End If
            End If
         End If
      End If
   End If

   ' ============ PICK A UNIT WITH 1-4 ============
   If MODE=1
      If Key State($2)
         If P1=0
            P1=1
            PICKN=0
            TRY_PICK
         End If
      Else
         P1=0
      End If
      If Key State($3)
         If P2=0
            P2=1
            PICKN=1
            TRY_PICK
         End If
      Else
         P2=0
      End If
      If Key State($4)
         If P3=0
            P3=1
            PICKN=2
            TRY_PICK
         End If
      Else
         P3=0
      End If
      If Key State($5)
         If P4=0
            P4=1
            PICKN=3
            TRY_PICK
         End If
      Else
         P4=0
      End If
   End If

   ' ============ SPACE: title -> story -> instr -> game ============
   If Key State($39)
      If PSPC=0
         PSPC=1
         NMODE=MODE
         If MODE=0
            Cls 0
            BLANK_HUD
            DRAW_STORY
            MSG$="the park chooses sides..."
            DICE$=""
            SCORE$="WINS M "+MWINS+" B "+BWINS
            STORY$=""
            NMODE=5
         End If
         If MODE=5
            Cls 0
            BLANK_HUD
            DRAW_INSTR
            MSG$="read up, soldier"
            DICE$=""
            STORY$=""
            NMODE=4
         End If
         If MODE=4
            INIT_GAME
            Cls 0
            BLANK_HUD
            MAKE_HUD
            DRAW_BOARD
            DRAW_UNITS
            DRAW_PANEL
            MSG$="MAMMALS GO - PICK 1-4"
            DICE$="Exploit unit weaknesses."
            SCORE$="KILLS M 0 B 0"
            SQH$="YOUR SQUAD"
            STORY$="War begins!"
            NMODE=1
         End If
         If MODE=2
            FINISH_UNIT
            If GOVER=1
               If WTEAM=0
                  MSG$="MAMMALS WIN - SPACE = MENU"
                  STORY$="Yann: Furrtastic!"
               Else
                  MSG$="BIRDS WIN - SPACE = MENU"
                  STORY$="Gael: A feathered paradise!"
               End If
               NMODE=3
            Else
               NMODE=1
            End If
         End If
         If MODE=3
            Cls 0
            BLANK_HUD
            DRAW_WINS
            MSG$="press space for the title"
            DICE$=""
            SCORE$=""
            STORY$=""
            NMODE=6
         End If
         If MODE=6
            Cls 0
            BLANK_HUD
            DRAW_TITLE
            MSG$="click the game, then space"
            DICE$=""
            SCORE$="WINS M "+MWINS+" B "+BWINS
            STORY$="rematch, anyone"
            NMODE=0
         End If
         MODE=NMODE
      End If
   Else
      PSPC=0
   End If

   ' ============ ESC: end move / back out ============
   If Key State($1)
      If PESC=0
         PESC=1
         NMODE=MODE
         If MODE=1
            Cls 0
            BLANK_HUD
            MAKE_HUD
            DRAW_TITLE
            MSG$="click the game, then space"
            DICE$=""
            SCORE$="WINS M "+MWINS+" B "+BWINS
            STORY$=""
            NMODE=0
         End If
         If MODE=5
            Cls 0
            BLANK_HUD
            MAKE_HUD
            DRAW_TITLE
            MSG$="click the game, then space"
            DICE$=""
            SCORE$="WINS M "+MWINS+" B "+BWINS
            STORY$=""
            NMODE=0
         End If
         If MODE=4
            Cls 0
            BLANK_HUD
            MAKE_HUD
            DRAW_TITLE
            MSG$="click the game, then space"
            DICE$=""
            SCORE$="WINS M "+MWINS+" B "+BWINS
            STORY$=""
            NMODE=0
         End If
         If MODE=2
            FINISH_UNIT
            If GOVER=1
               If WTEAM=0
                  MSG$="MAMMALS WIN - SPACE = MENU"
                  STORY$="Yann: Furrtastic!"
               Else
                  MSG$="BIRDS WIN - SPACE = MENU"
                  STORY$="Gael: A feathered paradise!"
               End If
               NMODE=3
            Else
               NMODE=1
            End If
         End If
         MODE=NMODE
      End If
   Else
      PESC=0
   End If
Loop

' startup: build the HUD and show the title
' MAKE_HUD
' DRAW_TITLE
