        Global ScreenX, ScreenY
        ScreenX = 640
        ScreenY = 400

        Screen Open 1, 640, 400, 8, Hires
        Curs Off
        Double Buffer
        Autoback 0
        Paper 0 : Palette $0,$00A,$FF0,$FF0,$BBB,$AAA,$BBB,$CCC
        Load "gjs.abk" 'Game Jam Sprites

        'HUD
        scene = 1 'test
        last_action_pressed = 0
        action_pressed = 0
        hold_scene = 0

        'DEBUG
        debug_text = "DEBUG TEXT"
        debug_on = 0
        Global debug_text, debug_on


        'Game Intro
        'full_text = "As a patrolling officer, you guard a dangerous zone and confront any threats. Each encounter helps improve and upgrade your spaceship. You must stay alert and keep the area safe."
        Dim full_text_chars(177)
        full_text_last_index = 177
        'Spliting strings were not possible on this CRVJA version ):
        full_text_chars(0) = "A": full_text_chars(1) = "s": full_text_chars(2) = " ": full_text_chars(3) = "a": full_text_chars(4) = " ": full_text_chars(5) = "p": full_text_chars(6) = "a": full_text_chars(7) = "t": full_text_chars(8) = "r": full_text_chars(9) = "o"
        full_text_chars(10) = "l": full_text_chars(11) = "l": full_text_chars(12) = "i": full_text_chars(13) = "n": full_text_chars(14) = "g": full_text_chars(15) = " ": full_text_chars(16) = "o": full_text_chars(17) = "f": full_text_chars(18) = "f": full_text_chars(19) = "i"
        full_text_chars(20) = "c": full_text_chars(21) = "e": full_text_chars(22) = "r": full_text_chars(23) = ",": full_text_chars(24) = " ": full_text_chars(25) = "y": full_text_chars(26) = "o": full_text_chars(27) = "u": full_text_chars(28) = " ": full_text_chars(29) = "g"
        full_text_chars(30) = "u": full_text_chars(31) = "a": full_text_chars(32) = "r": full_text_chars(33) = "d": full_text_chars(34) = " ": full_text_chars(35) = "a": full_text_chars(36) = " ": full_text_chars(37) = "d": full_text_chars(38) = "a": full_text_chars(39) = "n"
        full_text_chars(40) = "g": full_text_chars(41) = "e": full_text_chars(42) = "r": full_text_chars(43) = "o": full_text_chars(44) = "u": full_text_chars(45) = "s": full_text_chars(46) = " ": full_text_chars(47) = "z": full_text_chars(48) = "o": full_text_chars(49) = "n"
        full_text_chars(50) = "e": full_text_chars(51) = " ": full_text_chars(52) = "a": full_text_chars(53) = "n": full_text_chars(54) = "d": full_text_chars(55) = " ": full_text_chars(56) = "c": full_text_chars(57) = "o": full_text_chars(58) = "n": full_text_chars(59) = "f"
        full_text_chars(60) = "r": full_text_chars(61) = "o": full_text_chars(62) = "n": full_text_chars(63) = "t": full_text_chars(64) = " ": full_text_chars(65) = "a": full_text_chars(66) = "n": full_text_chars(67) = "y": full_text_chars(68) = " ": full_text_chars(69) = "t"
        full_text_chars(70) = "h": full_text_chars(71) = "r": full_text_chars(72) = "e": full_text_chars(73) = "a": full_text_chars(74) = "t": full_text_chars(75) = "s": full_text_chars(76) = ".": full_text_chars(77) = " ": full_text_chars(78) = "E": full_text_chars(79) = "a"
        full_text_chars(80) = "c": full_text_chars(81) = "h": full_text_chars(82) = " ": full_text_chars(83) = "e": full_text_chars(84) = "n": full_text_chars(85) = "c": full_text_chars(86) = "o": full_text_chars(87) = "u": full_text_chars(88) = "n": full_text_chars(89) = "t"
        full_text_chars(90) = "e": full_text_chars(91) = "r": full_text_chars(92) = " ": full_text_chars(93) = "h": full_text_chars(94) = "e": full_text_chars(95) = "l": full_text_chars(96) = "p": full_text_chars(97) = "s": full_text_chars(98) = " ": full_text_chars(99) = "i"
        full_text_chars(100) = "m": full_text_chars(101) = "p": full_text_chars(102) = "r": full_text_chars(103) = "o": full_text_chars(104) = "v": full_text_chars(105) = "e": full_text_chars(106) = " ": full_text_chars(107) = "a": full_text_chars(108) = "n": full_text_chars(109) = "d"
        full_text_chars(110) = " ": full_text_chars(111) = "u": full_text_chars(112) = "p": full_text_chars(113) = "g": full_text_chars(114) = "r": full_text_chars(115) = "a": full_text_chars(116) = "d": full_text_chars(117) = "e": full_text_chars(118) = " ": full_text_chars(119) = "y"
        full_text_chars(120) = "o": full_text_chars(121) = "u": full_text_chars(122) = "r": full_text_chars(123) = " ": full_text_chars(124) = "s": full_text_chars(125) = "p": full_text_chars(126) = "a": full_text_chars(127) = "c": full_text_chars(128) = "e": full_text_chars(129) = "s"
        full_text_chars(130) = "h": full_text_chars(131) = "i": full_text_chars(132) = "p": full_text_chars(133) = ".": full_text_chars(134) = " ": full_text_chars(135) = "Y": full_text_chars(136) = "o": full_text_chars(137) = "u": full_text_chars(138) = " ": full_text_chars(139) = "m"
        full_text_chars(140) = "u": full_text_chars(141) = "s": full_text_chars(142) = "t": full_text_chars(143) = " ": full_text_chars(144) = "s": full_text_chars(145) = "t": full_text_chars(146) = "a": full_text_chars(147) = "y": full_text_chars(148) = " ": full_text_chars(149) = "a"
        full_text_chars(150) = "l": full_text_chars(151) = "e": full_text_chars(152) = "r": full_text_chars(153) = "t": full_text_chars(154) = " ": full_text_chars(155) = "a": full_text_chars(156) = "n": full_text_chars(157) = "d": full_text_chars(158) = " ": full_text_chars(159) = "k"
        full_text_chars(160) = "e": full_text_chars(161) = "e": full_text_chars(162) = "p": full_text_chars(163) = " ": full_text_chars(164) = "t": full_text_chars(165) = "h": full_text_chars(166) = "e": full_text_chars(167) = " ": full_text_chars(168) = "a": full_text_chars(169) = "r"
        full_text_chars(170) = "e": full_text_chars(171) = "a": full_text_chars(172) = " ": full_text_chars(173) = "s": full_text_chars(174) = "a": full_text_chars(175) = "f": full_text_chars(176) = "e": full_text_chars(177) = "."
        text_to_show = " "
        text_index = -1
        frame_counter = 0

        Dim lines(6)
        lines(0) = " ": lines(1) = " ": lines(2) = " ": lines(3) = " ": lines(4) = " ": lines(5) = " "
        line_length = 30
        line_index = 0
        break_index = 0



        Paper 0
        Palette
        $000,  '0 black
        $002,  '1 very dark blue
        $00A,  '2 dark blue
        $664,  '3 dim yellow (muted)
        $AA0,  '4 stronger yellow
        $888,  '5 gray
        $F00,  '6 red
        $FFF   '7 white

        'Background Drawing

        max_stars = 21
        'star groups a to b
        s_g_a = max_stars / 3
        s_g_b = s_g_a * 2
        s_g_c = s_g_b * 3
        Dim STARS_X(max_stars)
        Dim STARS_Y(max_stars)

        'Create Star Positions
        For i = 0 To max_stars
            STARS_X(i) = Rnd(ScreenX)
            STARS_Y(i) = Rnd(ScreenY)
        Next


        'Power Ups
        '0 - fire rate + , ink3
        '1 - proj radius + , ink4
        '2 - projectile speed + , ink5
        '3 - player lives , ink6
        '4 - player radius , ink7
        '5 - wall bullets ' all bullets are instantiated one right the onther
        '6 - one bullet ' one undestructable bullet is instantiated instead several

        Dim PLAYER_SCORE_GOALS(13)
        PLAYER_SCORE_GOALS(0) = 100 '+100
        PLAYER_SCORE_GOALS(1) = 200 '+100
        PLAYER_SCORE_GOALS(2) = 300 '+100
        PLAYER_SCORE_GOALS(3) = 450 '+150
        PLAYER_SCORE_GOALS(4) = 600 '+150
        PLAYER_SCORE_GOALS(5) = 750 '+150
        PLAYER_SCORE_GOALS(6) = 950 '+200
        PLAYER_SCORE_GOALS(7) = 1150 '+200
        PLAYER_SCORE_GOALS(8) = 1350 '+200
        PLAYER_SCORE_GOALS(9) = 1600 '+250
        PLAYER_SCORE_GOALS(10) = 1850 '+250
        PLAYER_SCORE_GOALS(11) = 2100 '+250
        PLAYER_SCORE_GOALS(12) = 2400 '+300
        PLAYER_SCORE_GOALS(13) = 99999


        powers_activated = 0
        score_goal = PLAYER_SCORE_GOALS(powers_activated)

        Dim power_list(13)




        'PAUSE
        PAUSE = 0
            


        'Player
        player_score = 0
        player_alive = 1
        player_x = 320
        player_y = 300
        player_radius = 20
        player_speed = 20 '5
        player_lives = 5 '3
        player_hit_timer = 0
        player_fire_delay = 25
        player_fire_timer = player_fire_delay

        'Enemies
        max_enemies = 16
        enemy_radius = 16
        enemy_move_speed = 1

        'Player projectiles
        max_player_proj = 10
        pla_proj_radius = 3
        proj_speed = 5

        'Enemy projectiles
        max_enemy_proj = 50
        proj_en_firedelay_range = 40
        ene_proj_radius = 3
        spawn_delay = 120

        difficulty_counter = 0

        init = 0

        '--------Globals
        Global init
        Global powers_activated, power_list(12), score_goal
        Global player_score, player_alive, player_x, player_y, player_radius, player_speed, player_lives, player_hit_timer
        Global max_enemies, enemy_radius, proj_speed, enemy_move_speed
        Global difficulty_counter
        Global proj_en_firedelay_range
        Global ENEMY_X(0), ENEMY_Y(0), ENEMY_ACTIVE(0), ENEMY_PAT(0)
        Global ENEMY_T(0), ENEMY_BX(0), ENEMY_SY(0), ENEMY_ST(0), ENEMY_DIR(0), ENEMY_FIREDELAY(0)
        Global max_player_proj, pla_proj_radius, PP_ACTIVE(0), PP_X(0), PP_Y(0)
        Global max_enemy_proj, ene_proj_radius,EP_ACTIVE(0), EP_X(0), EP_Y(0)

        Dim ENEMY_X(max_enemies)
        Dim ENEMY_Y(max_enemies)
        Dim ENEMY_ACTIVE(max_enemies)
        Dim ENEMY_PAT(max_enemies)
        Dim ENEMY_T(max_enemies)
        Dim ENEMY_BX(max_enemies)
        Dim ENEMY_SY(max_enemies)
        Dim ENEMY_ST(max_enemies)
        Dim ENEMY_DIR(max_enemies)
        Dim ENEMY_FIREDELAY(max_enemies)

        Dim PP_ACTIVE(max_player_proj)
        Dim PP_X(max_player_proj)
        Dim PP_Y(max_player_proj)

        Dim EP_ACTIVE(max_enemy_proj)
        Dim EP_X(max_enemy_proj)
        Dim EP_Y(max_enemy_proj)

        '--------Initialize player variables at the start of the game, and on reset.
        Procedure INITIALIZE_VARIABLES[a]
            'Player variables
            powers_activated = 0
            For i = 0 To 11
                power_list(i) = 0
            Next
            score_goal = PLAYER_SCORE_GOALS(powers_activated)

            player_score = 0
            player_alive = 1
            player_x = 320
            player_y = 300
            player_radius = 20 'Power 4
            player_speed = 10 
            player_lives = 5 'Power 3
            player_hit_timer = 0
            player_fire_delay = 25 'Power 0
            player_fire_timer = player_fire_delay
            proj_speed = 5 'Power 2
            pla_proj_radius = 3 'Power 1

            'Text variables

            text_to_show = " "  
            text_index = -1
            frame_counter = 0
            lines(0) = " ": lines(1) = " ": lines(2) = " ": lines(3) = " ": lines(4) = " ": lines(5) = " "
            line_length = 30
            line_index = 0
            break_index = 0

            difficulty_counter = 0
            'Enemy variables

            spawn_delay = 400
            proj_en_firedelay_range = 50
            enemy_move_speed = 1
            

            PLAYER_RESET[1]
            EnemyReset[1]

            init = 1

        End Proc

        '--------Knock a life off, reset the player, clear the board.
        Procedure PLAYER_HIT[a]
            player_lives = player_lives - 1
            player_hit_timer = 60
            'PLAYER_RESET[1]

            If player_lives < 1
                player_alive = 0
            End If
            Play 37,1
            'EnemyReset[1]
        End Proc

        Procedure PLAYER_RESET[a]
            player_x = ScreenX / 2
            player_y = ScreenY - 100
        End Proc

        '--------Fire one projectile straight up from the player.
        Procedure PLAYER_FIRE[a]
            index = 0
            For j = 1 To max_player_proj
                If PP_ACTIVE(j) = 0
                    index = j
                    j = max_player_proj
                End If
            Next
            If index > 0
                PP_ACTIVE(index) = 1
                px = player_x + 8
                PP_X(index) = px
                py = player_y - 8
                PP_Y(index) = py
            End If
        End Proc

        '--------Enemy fires one projectile straight down from its position.
        Procedure ENEMY_FIRE[index]
            slot = 0
            
            For j = 1 To max_enemy_proj
                If EP_ACTIVE(j) = 0
                    slot = j
                    j = max_enemy_proj
                End If
            Next
            If slot > 0
                EP_ACTIVE(slot) = 1
                ex = ENEMY_X(index)
                EP_X(slot) = ex
                ey = ENEMY_Y(index)
                ey = ey + 8
                EP_Y(slot) = ey
            End If
        End Proc

        '--------Move player projectiles up, deactivate off the top.
        Procedure MOVE_PLAYER_PROJ[a]
            For j = 1 To max_player_proj
                If PP_ACTIVE(j) = 1
                    cy = PP_Y(j)
                    ny = cy - proj_speed
                    PP_Y(j) = ny
                    If ny < 0
                        PP_ACTIVE(j) = 0
                    End If
                End If
            Next
        End Proc

        '--------Move enemy projectiles down, deactivate off the bottom.
        Procedure MOVE_ENEMY_PROJ[a]
            For j = 1 To max_enemy_proj
                If EP_ACTIVE(j) = 1
                    cy = EP_Y(j)
                    ny = cy + 6
                    EP_Y(j) = ny
                    If ny > ScreenY
                        EP_ACTIVE(j) = 0
                    End If
                End If
            Next
        End Proc

        '--------Player vs active enemy bodies (squared distance).
        Procedure CHECK_COLLISIONS[a]
            If player_hit_timer = 0
                cd = player_radius + enemy_radius
                cd2 = cd * cd
                For i = 1 To max_enemies
                    If ENEMY_ACTIVE(i) = 1
                        dx = player_x - ENEMY_X(i)
                        dy = player_y - ENEMY_Y(i)
                        d2 = dx*dx + dy*dy
                        If d2 < cd2
                            PLAYER_HIT[1]
                        End If
                    End If
                Next
            End If
        End Proc

        '--------Player projectiles vs enemies: both die on contact.
        Procedure CHECK_PP_HITS[a]
            cd = enemy_radius + pla_proj_radius
            cd2 = cd * cd
            For j = 1 To max_player_proj
                If PP_ACTIVE(j) = 1
                    For i = 1 To max_enemies
                        If ENEMY_ACTIVE(i) = 1
                            dx = PP_X(j) - ENEMY_X(i)
                            dy = PP_Y(j) - ENEMY_Y(i)
                            d2 = dx*dx + dy*dy
                            If d2 < cd2
                                ENEMY_ACTIVE(i) = 0
                                PP_ACTIVE(j) = 0
                            End If
                        End If
                    Next
                End If
            Next
        End Proc

        '--------Enemy projectiles vs player: bullet dies, player takes a hit.
        Procedure CHECK_EP_HITS[a]
            If player_hit_timer = 0
                cd = player_radius + ene_proj_radius
                cd2 = cd * cd
                For j = 1 To max_enemy_proj
                    If EP_ACTIVE(j) = 1
                        dx = player_x - EP_X(j)
                        dy = player_y - EP_Y(j)
                        d2 = dx*dx + dy*dy
                        If d2 < cd2
                            EP_ACTIVE(j) = 0
                            PLAYER_HIT[1]
                        End If
                    End If
                Next
            End If
        End Proc

        Procedure DRAW_PLAYER[a]
            temp_x = player_x - 16
            temp_y = player_y - 16
            Sprite 0, temp_x, temp_y, 1
            Ink 3
            Circle player_x, player_y, player_radius
        End Proc

        '--------Draw active player projectiles as circles.
        Procedure DRAW_PP[a]
            Ink 6
            For j = 1 To max_player_proj
                If PP_ACTIVE(j) = 1
                    tempx = PP_X(j)
                    tempy = PP_Y(j)
                    Circle tempx, tempy, pla_proj_radius
                End If
            Next
        End Proc

        '--------Draw active enemy projectiles as circles (different ink so you can tell them apart).
        Procedure DRAW_EP[a]
            Ink 6
            For j = 1 To max_enemy_proj
                If EP_ACTIVE(j) = 1
                    tempx = EP_X(j)
                    tempy = EP_Y(j)
                    Circle tempx, tempy, ene_proj_radius
                End If
            Next
        End Proc

        '--------Draw powers as a row of pips (redrawn each frame, so no leak).
        Procedure DRAW_POWERS[a]
            Ink 4
            For li = 1 To powers_activated
                If power_list(li) = 0 Ink 3 End If
                If power_list(li) = 1 Ink 4 End If
                If power_list(li) = 2 Ink 5 End If
                If power_list(li) = 3 Ink 6 End If
                If power_list(li) = 4 Ink 7 End If
                lx = li * 16
                Circle lx, 16, 5
            Next
        End Proc

        '--------Grab a random 2-3 inactive enemies and start them on a pattern.
        'Each freshly-spawned enemy also gets its own random fire countdown.
        Procedure SPAWN_GROUP[pat]
            count = 2 + Rnd(1)
            made = 0
            For i = 1 To max_enemies
                If ENEMY_ACTIVE(i) = 0
                    If made < count
                        ENEMY_ACTIVE(i) = 1
                        ENEMY_PAT(i) = pat
                        ENEMY_ST(i) = 0
                        off = made * 20
                        bx = Rnd(440) + off + 50 '540 is range + offset + 50 padding
                        ENEMY_BX(i) = bx
                        ENEMY_X(i) = bx
                        ENEMY_Y(i) = 0 - 20
                        ph = made * 20
                        ENEMY_T(i) = ph
                        sy = Rnd(200) + 100
                        ENEMY_SY(i) = sy
                        rr = Rnd(1)
                        dd = 0 - 1
                        If rr = 1
                            dd = 1
                        End If
                        ENEMY_DIR(i) = dd
                        fd = Rnd(proj_en_firedelay_range)
                        fd = fd + 10
                        ENEMY_FIREDELAY(i) = fd
                        made = made + 1
                    End If
                End If
            Next
        End Proc

        '--------Clear the board (deactivate every enemy AND every enemy bullet).
        Procedure EnemyReset[a]
            For i = 1 To max_enemies
                ENEMY_ACTIVE(i) = 0
            Next
            For j = 1 To max_enemy_proj
                EP_ACTIVE(j) = 0
            Next
        End Proc

        '--------Draw only the ACTIVE enemies (DRAW does a Cls first, so skipped
        'enemies just aren't recreated). Sprite numbers are literal: enemy i -> sprite (i+1).
        Procedure DRAW_ENEMIES[a]

            hs = 16 'half sprite size for centering
            If ENEMY_ACTIVE(1) = 1
                tempx = ENEMY_X(1) - hs
                tempy = ENEMY_Y(1) - hs
                Sprite 2, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(2) = 1
                tempx = ENEMY_X(2) - hs
                tempy = ENEMY_Y(2) - hs
                Sprite 3, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(3) = 1
                tempx = ENEMY_X(3) - hs
                tempy = ENEMY_Y(3) - hs
                Sprite 4, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(4) = 1
                tempx = ENEMY_X(4) - hs
                tempy = ENEMY_Y(4) - hs
                Sprite 5, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(5) = 1
                tempx = ENEMY_X(5) - hs
                tempy = ENEMY_Y(5) - hs
                Sprite 6, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(6) = 1
                tempx = ENEMY_X(6) - hs
                tempy = ENEMY_Y(6) - hs
                Sprite 7, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(7) = 1
                tempx = ENEMY_X(7) - hs
                tempy = ENEMY_Y(7) - hs
                Sprite 8, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(8) = 1
                tempx = ENEMY_X(8) - hs
                tempy = ENEMY_Y(8) - hs
                Sprite 9, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(9) = 1
                tempx = ENEMY_X(9) - hs
                tempy = ENEMY_Y(9) - hs
                Sprite 10, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(10) = 1
                tempx = ENEMY_X(10) - hs
                tempy = ENEMY_Y(10) - hs
                Sprite 11, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(11) = 1
                tempx = ENEMY_X(11) - hs
                tempy = ENEMY_Y(11) - hs
                Sprite 12, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(12) = 1
                tempx = ENEMY_X(12) - hs
                tempy = ENEMY_Y(12) - hs
                Sprite 13, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(13) = 1
                tempx = ENEMY_X(13) - hs
                tempy = ENEMY_Y(13) - hs
                Sprite 14, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(14) = 1
                tempx = ENEMY_X(14) - hs
                tempy = ENEMY_Y(14) - hs
                Sprite 15, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(15) = 1
                tempx = ENEMY_X(15) - hs
                tempy = ENEMY_Y(15) - hs
                Sprite 16, tempx, tempy, 0
            End If
            If ENEMY_ACTIVE(16) = 1
                tempx = ENEMY_X(16) - hs
                tempy = ENEMY_Y(16) - hs
                Sprite 17, tempx, tempy, 0
            End If

            Ink 3
            For i = 1 To max_enemies
                If ENEMY_ACTIVE(i) = 1
                    tempx = ENEMY_X(i)
                    tempy = ENEMY_Y(i)
                    Circle tempx, tempy, enemy_radius
                End If
            Next
        End Proc

        '--------Draw everything. Cls clears the whole playfield (sprites AND circles),
        'then we rebuild the lives, player, active enemies, and both bullet pools.
        Procedure DRAW[a]
            Cls
            DRAW_POWERS[1]
            DRAW_PLAYER[1]
            DRAW_ENEMIES[1]
            DRAW_PP[1]
            DRAW_EP[1]
        End Proc

        '--------Move enemies by pattern, and tick down each one's fire timer.
        '1 = dive from top, hold a couple seconds, then exit to the side
        '2 = sine-wave descent (side to side)
        '3 = orbit the player
        Procedure MOVE_ENEMIES[a]
            For i = 1 To max_enemies
                If ENEMY_ACTIVE(i) = 1

                    '----fire countdown: when it hits 0, shoot and roll a new delay
                    fd = ENEMY_FIREDELAY(i)
                    fd = fd - 1
                    ENEMY_FIREDELAY(i) = fd
                    If fd < 1
                        ENEMY_FIRE[i]
                        nf = Rnd(proj_en_firedelay_range)
                        nf = nf + 10
                        ENEMY_FIREDELAY(i) = nf
                    End If

                    pat = ENEMY_PAT(i)

                    If pat = 1
                        st = ENEMY_ST(i)
                        If st = 0
                            cy = ENEMY_Y(i)
                            sy = ENEMY_SY(i)
                            If cy < sy
                                ny = cy + enemy_move_speed
                                ENEMY_Y(i) = ny
                            Else
                                ENEMY_ST(i) = 1
                                ENEMY_T(i) = 60
                            End If
                        End If
                        If st = 1
                            ht = ENEMY_T(i)
                            If ht > 0
                                nt = ht - 1
                                ENEMY_T(i) = nt
                            Else
                                ENEMY_ST(i) = 2
                            End If
                        End If
                        If st = 2
                            dir = ENEMY_DIR(i)
                            cx = ENEMY_X(i)
                            sxx = dir * 3
                            nx = cx + sxx
                            ENEMY_X(i) = nx
                            If nx < 0
                                ENEMY_ACTIVE(i) = 0
                                PLAYER_HIT[1]
                            End If
                            If nx > ScreenX
                                ENEMY_ACTIVE(i) = 0
                                PLAYER_HIT[1]
                            End If
                        End If
                    End If

                    If pat = 2
                        cy = ENEMY_Y(i)
                        ny = cy + enemy_move_speed
                        ENEMY_Y(i) = ny
                        ph = ENEMY_T(i)
                        ox = Qsin(ph, 90)
                        bx = ENEMY_BX(i)
                        nx = bx + ox
                        ENEMY_X(i) = nx
                        np = ph + 6
                        ENEMY_T(i) = np
                        If ny > ScreenY
                            ENEMY_ACTIVE(i) = 0
                            PLAYER_HIT[1]
                        End If
                    End If

                    If pat = 3
                        ph = ENEMY_T(i)
                        ox = Qcos(ph, 70)
                        oy = Qsin(ph, 70)
                        nx = player_x + ox
                        ENEMY_X(i) = nx
                        ny = player_y + oy
                        ENEMY_Y(i) = ny
                        np = ph + 5
                        ENEMY_T(i) = np
                        If np > 1536
                            ENEMY_ACTIVE(i) = 0
                            PLAYER_HIT[1]
                        End If
                    End If
                End If
            Next
        End Proc

        '--------Init both projectile pools inactive (so slot searches and draw checks work).
        For j = 1 To max_player_proj
            PP_ACTIVE(j) = 0
        Next
        For j = 1 To max_enemy_proj
            EP_ACTIVE(j) = 0
        Next

        '--------Game Loop
        spawn_timer = 1
        PLAYER_RESET[1]
        EnemyReset[1]

        'SOUND TESTS
        frame=0
        step = 0
        melody_lenght=32

        frame_counter = 0
        step_length = 50

        sound_on = 0

        Dim melody(31)

        melody(0)=48 : melody(1)=50 : melody(2)=52 : melody(3)=50
        melody(4)=48 : melody(5)=46 : melody(6)=48 : melody(7)=50
        melody(8)=52 : melody(9)=54 : melody(10)=52 : melody(11)=50
        melody(12)=48 : melody(13)=46 : melody(14)=48 : melody(15)=50
        melody(16)=52 : melody(17)=54 : melody(18)=56 : melody(19)=52
        melody(20)=50 : melody(21)=48 : melody(22)=50 : melody(23)=52
        melody(24)=54 : melody(25)=52 : melody(26)=50 : melody(27)=48
        melody(28)=46 : melody(29)=48 : melody(30)=50 : melody(31)=48

        'END  SOUND TESTS

        Do
            'DEBUG AND DEV CONTROL
            If scene = 99
                INITIALIZE_VARIABLES[1] ' Initialize variables here
                scene = 3
            End If

            
            
            If Key State($06) 
            scene = 1
            INITIALIZE_VARIABLES[1] End If
            If Key State($07) scene = 2 End If
            If Key State($08) scene = 3 End If
            If Key State($09) scene = 4 End If

            'END DEBUG
            last_action_pressed = action_pressed
            action_pressed = 0
            If Key State($39) action_pressed = 1 End If
            If action_pressed = 0 hold_scene = 0 End If

            'Background Sound
            
            If Key State($19) 
                If sound_on = 1 
                    sound_on = 0 
                Else sound_on = 1 End If
            End If
            
            If sound_on = 1
            'Plays one note every step_length frames, iterating through the melody array. Resets to the beginning after reaching the end of the array.
                frame_counter = frame_counter + 1
                If frame_counter > step_length
                    frame_counter = 0
                    
                    If step > melody_lenght-1 
                        step = 0
                    End If
                    n1 = melody(step)
                    
                    Play n1,1 

                    step = step + 1
                End If
            End If     

            'END Background Sound

            Ink 4

            ' This is the first scene - Main Menu
            If scene = 1
                'Initialize variables here
                Cls 0
                If init = 0
                    INITIALIZE_VARIABLES[1]
                End If

                'Reset on game over
                player_alive = 1
                mid = ScreenX / 2
                Ink 4
                x = mid - 27*8
                Text x, 120, "Re-Animate 2026 - Game Jam"'26
                
                Ink 4
                x = mid - 14*8
                Text x, 150, "Galaxy Patrol"'13
                
                Ink 7
                x = mid - 20*8
                Text x, 200, "Press Space to Play"'19
                
                Ink 7
                Text 30, 270, "A game by: Diego Tondorf, Kevin Chua,"
                Text 30, 290, "Minette Zongo and Tahereh Bijani"

                If hold_scene = 0
                    If action_pressed = 1
                        If last_action_pressed = 0
                            scene = 2
                            
                            text_to_show = " "
                            text_index = -1
                            frame_counter = 0
                            lines(0) = " ": lines(1) = " ": lines(2) = " ": lines(3) = " ": lines(4) = " ": lines(5) = " "
                            line_length = 30
                            line_index = 0
                            break_index = 0
                            
                            hold_scene = 1
                        End If
                    End If
                End If
            End If

            ' This is the second scene - Game Intro
            If scene = 2
                Cls 0
            
                If text_index < full_text_last_index
                    text_index = text_index + 1
                    'Wait 3
                    text_to_show = text_to_show + full_text_chars(text_index)
                    lines(line_index) = text_to_show
                    
                End If
                Ink 7
                If text_index > break_index + line_length
                    If full_text_chars(text_index) = " "
                        text_to_show = " "
                        line_index = line_index +1
                        break_index = text_index
                    End If
                End If
                aux_text = lines(0)
                Text 30, 30, aux_text
                aux_text = lines(1)
                Text 30, 50, aux_text
                aux_text = lines(2)
                Text 30, 70, aux_text
                aux_text = lines(3)
                Text 30, 90, aux_text
                aux_text = lines(4)
                Text 30, 110, aux_text
                aux_text = lines(5)
                Text 30, 130, aux_text

                Ink 5
                x = mid - 20*8
                Text x, 200, "Press Space to Continue"

                x = mid - 16*8
                Text x, 280, "W, A, S, D To move"

                If hold_scene = 0
                    If action_pressed = 1
                        If last_action_pressed = 0
                            scene = 3
                            hold_scene = 1
                        End If
                    End If
                End If
            End If

            ' This is the third scene - Game playing
            If scene = 3
                '--------Check input
                If Key State($1F)
                    player_y = player_y + player_speed
                    If player_y > ScreenY - 16
                        player_y = ScreenY - 16
                    End If
                End If
                If Key State($11)
                    player_y = player_y - player_speed
                    If player_y < 16
                        player_y = 16
                    End If
                End If
                If Key State($20)
                    player_x = player_x + player_speed
                    If player_x > ScreenX - 16
                        player_x = ScreenX - 16
                    End If
                End If
                If Key State($1E)
                    player_x = player_x - player_speed
                    If player_x < 16
                        player_x = 16
                    End If
                End If

                '--------invincibility countdown
                If player_hit_timer > 0
                    player_hit_timer = player_hit_timer - 1
                End If

                '--------player auto-fire upward
                player_fire_timer = player_fire_timer - 1
                If player_fire_timer < 1
                    PLAYER_FIRE[1]
                    player_fire_timer = player_fire_delay
                End If

                '--------spawn a random-pattern group every so often
                spawn_timer = spawn_timer - 1
                If spawn_timer < 1
                    p = 1 + Rnd(1)
                    SPAWN_GROUP[p]
                    spawn_timer = spawn_delay
                End If

                MOVE_ENEMIES[1]
                MOVE_PLAYER_PROJ[1]
                MOVE_ENEMY_PROJ[1]
                CHECK_COLLISIONS[1]
                CHECK_PP_HITS[1]
                CHECK_EP_HITS[1]

                '-------------DRAW
                DRAW[1]

                'Background Drawing
                'Move stars
                A_Spd = 1
                B_Spd = 2
                C_Spd = 3
                Spd = 0

                For i = 0 To max_stars
                    If i < s_g_a Spd = A_Spd End If
                    If i > s_g_a - 1 If i < s_g_b Spd = B_Spd End If End If
                    If i > s_g_b - 1 If i < s_g_c Spd = C_Spd End If End If

                    auxY = STARS_Y(i) + Spd

                    If auxY > ScreenY
                        STARS_X(i) = Rnd(ScreenX)
                        auxY = 0
                    End If
                    STARS_Y(i) = auxY
                Next
                'END Move Stars

                'Draw stars
                For i = 0 To max_stars
                    If i < s_g_a Ink 3 End If
                    If i > s_g_a - 1 If i < s_g_b Ink 4 End If End If
                    If i > s_g_b - 1 If i < s_g_c Ink 5 End If End If

                    AX = STARS_X(i)
                    AY = STARS_Y(i)

                    Circle AX,AY,2
                Next
                'END draw stars

                'DRAW HUD
                player_score = player_score + 1
                text_a = "Player Score:" + player_score
                Text 100, ScreenY - 30, text_a

                text_b = "Lives:" + player_lives
                Text 500, ScreenY - 30, text_b
                'END draw HUD

                '--------PauseHUD
                'If PAUSE = 1
                '   Text 300, 200, "PAUSED"
                '    If Key State($19)
                '       'Wait 5
                '        PAUSE = 0
                '    End If
                'End If

                If PAUSE = 0
                    If Key State($19)
                        PAUSE = 1
                        'Wait 5
                    End If
                End If

                'Increase Difficulty
                
                difficult_counter = difficult_counter + 1
                If difficult_counter > 250
                    difficult_counter = 0
                
                    If proj_en_firedelay_range > 20
                        proj_en_firedelay_range = proj_en_firedelay_range - 5
                    End If

                    If enemy_move_speed < 10
                        enemy_move_speed = enemy_move_speed + 1
                    End If
    


                End If
                aux_t =  "Spawn Timer: " + proj_en_firedelay_range
                Debug_text = aux_t



                'End Increase Difficulty

                '---------Power Ups
                '0 - projectile qtd +
                '1 - projectile scale +
                '2 - projectile speed +
                '3 - player lives , ink6

                
                If player_score > score_goal
                    powers_activated = powers_activated + 1
                    score_goal = PLAYER_SCORE_GOALS(powers_activated)

                    choice = Rnd(4)
                    'choice = 0 
                    
                    power_list(powers_activated) = choice  

                    If choice = 0
                        If player_fire_delay > 5 
                            player_fire_delay = player_fire_delay - 3
                        End If
                    End If
                    If choice = 1
                        pla_proj_radius = pla_proj_radius + 1
                    End If
                    If choice = 2
                        proj_speed = proj_speed + 5
                    End If
                    If choice = 3
                        player_lives = player_lives + 2
                    End If
                    If choice = 4
                        If player_radius > 6
                            player_radius = player_radius - 2   
                        End If
                    End If
                End If

                'END Power Ups
                'Wait 5

                If player_lives < 1
                    scene = 4
                End If
            End If

            'This is Game Over scene
            If scene = 4
                Cls 0
                Ink 4
                Text 100, 120, "Game Over!"
                aux_t = "Final Score: " + player_score
                Ink 7
                Text 100, 150, aux_t
                Ink 4
                Text 100, 200, "Thanks for playing!"
                If action_pressed = 1
                    If last_action_pressed = 0
                        init = 0
                        scene = 1
                    End If
                End If
            End If

            'Visualizing Debugging
            If debug_on = 1
                Ink 7
                aux = "DBG: "+debug_text
                Text 13, 13, aux
                Ink 6
                Bar 10,10 To 640,30
            End If

            Wait Vbl
        Loop
        End