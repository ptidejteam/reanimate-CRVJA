Screen Open 1, 408, 520, 1, Hires

Paper 0 : Palette $A83,$EC3,$D70,$0F0,$333,$BAA,$ECA,$A99

Load "sprites.abk"

MAP_SIZE = 16
TILE_SIZE = 24
Dim map(MAP_SIZE, MAP_SIZE)

Dim exploding_tiles(MAP_SIZE, MAP_SIZE)
Dim fog(MAP_SIZE, MAP_SIZE)

'MAP DEFINITIONS
'1 = NOT BREAKABLE WALL
'2 = WALKABLE
'3 = BREAKABLE WALLS
'4 = BUFF 1
'5 = BUFF 2

'Srite IDs
'1 : Player 1
'2 : Bomb P1
'3-11 : Bomb explosion P1
'12 : Player 2
'13 : Bomb P2
'14-22 : Bomb explosion P2

MOVE_DELAY = 8
MOVE_TIMER = 0
MOVE_TIMER_P2 = 0

GAME_FINISHED = 0
CURRENT_LEVEL = 1

BASE_SPAWN_RATE = 50

BASE_MONSTER_MOVE_DELAY = 30
MONSTER_MOVE_DELAY = BASE_MONSTER_MOVE_DELAY - CURRENT_LEVEL * 2
If MONSTER_MOVE_DELAY < 8
   MONSTER_MOVE_DELAY = 8
End If
   SPAWN_RATE = BASE_SPAWN_RATE - 5 * CURRENT_LEVEL
If SPAWN_RATE < 0
   SPAWN_RATE = 0
End If' Initialize game variables
PLAYER_1_DIED = 0
PLAYER_2_DIED = 0
PLAYER_1_LIFE = 3
PLAYER_2_LIFE = 3
PX = MAP_SIZE / 2 : PY = MAP_SIZE / 2
P2X = MAP_SIZE / 2 : P2Y = MAP_SIZE / 2
    
PLAYER_1_ANIM = 0
PLAYER_1_DIR = 0

PLAYER_2_ANIM = 0
PLAYER_2_DIR = 0


CURRENT_DAMAGE_COOLDOWN_P1 = 0
CURRENT_DAMAGE_COOLDOWN_P2 = 0
DAMAGE_COOLDOWN = 100
BOMB_X = 0 : BOMB_Y = 0 : BOMB_ACTIVE = 0
BOMB_X_P2 = 0 : BOMB_Y_P2 = 0 : BOMB_ACTIVE_P2 = 0
EXPL_X = 0 : EXPL_Y = 0
EXPL_X_P2 = 0 : EXPL_Y_P2 = 0
BOMB_FUSE = 75   ' frames until explosion (about 3 seconds at 50fps)
EXPL_DURATION = 40 ' frames the explosion lingers (about 1.5 seconds)
BOMB_TIMER = 0
BOMB_TIMER_P2 = 0
EXPL_TIMER = 0
EXPL_TIMER_P2 = 0
EXPL_ACTIVE = 0
EXPL_ACTIVE_P2 = 0

' Coordinates where we put unsued / detroyed sprites
TRASH_X = 30 * TILE_SIZE
TRASH_Y = 40 * TILE_SIZE

' Monster related variables
MAX_MONSTERS = 2
CURRENT_MONSTERS = 0

' Monsters variables
MONSTER_ONE_ALIVE = 0
MONSTER_ONE_TYPE = 0
MONSTER_TWO_ALIVE = 0
MONSTER_TWO_TYPE = 0
P_MONSTER_ONE_X = 3 : P_MONSTER_ONE_Y = 3
P_MONSTER_TWO_X = 3 : P_MONSTER_TWO_Y = 3

MONSTER_ONE_ANIMATION = 0
MONSTER_TWO_ANIMATION = 0

MONSTER_ONE_TIMER = 0
MONSTER_TWO_TIMER = 0 
MONSTER_SPAWN_TIMER = 0
MONSTER_SPAWN_DELAY = 150

' Milk healing item
MILK_ACTIVE = 0
MILK_X = 0
MILK_Y = 0
MAX_PLAYER_LIFE = 3

GAME_STATE = 0

Global MAP_SIZE, TILE_SIZE, PX, PY, P2X, P2Y, map(), fog(), BOMB_X, BOMB_Y, BOMB_ACTIVE, BOMB_TIMER, EXPL_TIMER, EXPL_ACTIVE, BOMB_FUSE, EXPL_DURATION, MOVE_DELAY, MOVE_TIMER, MOVE_TIMER_P2, PLAYER_1_DIED
Global MAX_MONSTERS, CURRENT_MONSTERS, GAME_FINISHED, BOMB_ACTIVE_P2 , PLAYER_1_DIR, PLAYER_2_DIR, PLAYER_1_ANIM, PLAYER_2_ANIM, PLAYER_2_DIED, PLAYER_1_LIFE, CURRENT_DAMAGE_COOLDOWN_P1, DAMAGE_COOLDOWN, BOMB_X_P2, BOMB_Y_P2, CURRENT_DAMAGE_COOLDOWN_P2, PLAYER_2_LIFE, BOMB_TIMER_P2, EXPL_TIMER_P2, EXPL_ACTIVE_P2
Global MONSTER_ONE_TYPE, MONSTER_TWO_TYPE, MONSTER_ONE_ANIMATION, MONSTER_TWO_ANIMATION, MONSTER_TWO_ALIVE, MONSTER_ONE_ALIVE, MONSTER_MOVE_DELAY, MONSTER_ONE_TIMER, MONSTER_TWO_TIMER, P_MONSTER_ONE_X, P_MONSTER_ONE_Y, P_MONSTER_TWO_X, P_MONSTER_TWO_Y 
Global TRASH_X, TRASH_Y
Global EXPL_X, EXPL_Y, EXPL_X_P2, EXPL_Y_P2
Global MILK_ACTIVE, MILK_X, MILK_Y, MAX_PLAYER_LIFE
Global SPAWN_RATE, CURRENT_LEVEL, BASE_SPAWN_RATE, BASE_MONSTER_MOVE_DELAY 

For x = 0 To MAP_SIZE - 1
  For y = 0 To MAP_SIZE - 1
     map(x, y) = 1
     fog(x, y) = 1
     exploding_tiles(x, y) = 0
  Next
Next

Procedure PROC_UPDATE_FOG[x, y]
  For xi = x - 3 To x + 3
     For yi = y - 3 To y + 3
        If xi >= 0
           If xi <= MAP_SIZE - 1
              If yi >= 0
                 If yi <= MAP_SIZE - 1
                    fog_distance = (xi - x) * (xi - x) + (yi - y) * (yi - y)
                    If fog_distance < 6
                       fog(xi, yi) = 0
                    End If
                 End If
              End If
           End If
        End If
     Next
  Next
End Proc

Procedure PROC_DRAW_BOMB_P1
  X1 = BOMB_X * TILE_SIZE + 4
  Y1 = BOMB_Y * TILE_SIZE + 4
  Sprite 2, X1, Y1, 0
End Proc

Procedure PROC_DRAW_BOMB_P2
  X1 = BOMB_X_P2 * TILE_SIZE + 4
  Y1 = BOMB_Y_P2 * TILE_SIZE + 4
  Sprite 13, X1, Y1, 0
End Proc

Procedure PROC_TRY_DROP_MILK[x, y]
  If MILK_ACTIVE = 0
     ' One chance in four for each destroyed wall
     If Rnd(3) = 0
        MILK_X = x
        MILK_Y = y
        MILK_ACTIVE = 1
     End If
  End If
End Proc

Procedure PROC_DRAW_MILK
  If MILK_ACTIVE = 1
     If fog(MILK_X, MILK_Y) = 0
        milk_screen_x = MILK_X * TILE_SIZE
        milk_screen_y = MILK_Y * TILE_SIZE
        ' Channel 25 uses image 14 from the sprite bank
        Sprite 25, milk_screen_x, milk_screen_y, 13
     Else
        Sprite 25, TRASH_X, TRASH_Y, 13
     End If
  Else
     Sprite 25, TRASH_X, TRASH_Y, 13
  End If
End Proc

Procedure PROC_CHECK_MILK
  If MILK_ACTIVE = 1
     If PLAYER_1_DIED = 0
        If PX = MILK_X
           If PY = MILK_Y
              If PLAYER_1_LIFE < MAX_PLAYER_LIFE
                 PLAYER_1_LIFE = PLAYER_1_LIFE + 1
              End If
              MILK_ACTIVE = 0
              Sprite 25, TRASH_X, TRASH_Y, 13
           End If
        End If
     End If
     If MILK_ACTIVE = 1
        If PLAYER_2_DIED = 0
           If P2X = MILK_X
              If P2Y = MILK_Y
                 If PLAYER_2_LIFE < MAX_PLAYER_LIFE
                    PLAYER_2_LIFE = PLAYER_2_LIFE + 1
                 End If
                 MILK_ACTIVE = 0
                 Sprite 25, TRASH_X, TRASH_Y, 13
              End If
           End If
        End If
     End If
  End If
End Proc

Procedure PROC_DRAW_EXPLOSION_H
  tile_broken = 0
  CY = EXPL_Y * TILE_SIZE + 4


  X = EXPL_X * TILE_SIZE + 4
  Sprite 3, X, CY, 1
  exploding_tiles(EXPL_X, EXPL_Y) = 1
  ' We check if the explosion is in a wall for the closest tiles
  ' Then we check the next ones
  If map(EXPL_X + 1, EXPL_Y) = 2
     tmp = EXPL_X + 1
     exploding_tiles(tmp, EXPL_Y) = 1
    
     X = X + TILE_SIZE
     Sprite 4, X, CY, 2
     If map(EXPL_X + 2, EXPL_Y) > 1
        tmp = EXPL_X + 2
        If map(EXPL_X + 2, EXPL_Y) = 3
           map(tmp, EXPL_Y) = 2
           tile_broken = 1
           PROC_TRY_DROP_MILK[tmp, EXPL_Y]
        End If
        exploding_tiles(EXPL_X + 2, EXPL_Y) = 1
        X = X + TILE_SIZE
        Sprite 5, X, CY, 2
     End If

  End If
  If map(EXPL_X + 1, EXPL_Y) = 3
     tmp = EXPL_X + 1
     map(tmp, EXPL_Y) = 2
     tile_broken = 1
     PROC_TRY_DROP_MILK[tmp, EXPL_Y]
     exploding_tiles(tmp, EXPL_Y) = 1
    
     X = X + TILE_SIZE
     Sprite 4, X, CY, 2
  End If
  If map(EXPL_X - 1, EXPL_Y) = 2
     tmp = EXPL_X - 1
     exploding_tiles(tmp, EXPL_Y) = 1
     X = (EXPL_X - 1) * TILE_SIZE + 4
     Sprite 6, X, CY, 2
     If map(EXPL_X - 2, EXPL_Y) > 1
        tmp = EXPL_X - 2
        If map(EXPL_X - 2, EXPL_Y) = 3
           map(tmp, EXPL_Y) = 2
           tile_broken = 1
           PROC_TRY_DROP_MILK[tmp, EXPL_Y]
        End If
        exploding_tiles(tmp, EXPL_Y) = 1
        X = X - TILE_SIZE
        Sprite 7, X, CY, 2
     End If
  End If
  If map(EXPL_X - 1, EXPL_Y) = 3
     tmp = EXPL_X - 1
     map(tmp, EXPL_Y) = 2
     tile_broken = 1
     PROC_TRY_DROP_MILK[tmp, EXPL_Y]
     exploding_tiles(tmp, EXPL_Y) = 1
    
     X = (EXPL_X - 1) * TILE_SIZE + 4
     Sprite 6, X, CY, 2
  End If
  If tile_broken = 1
     PROC_DRAW_MAP
     PROC_DRAW_MILK
  End If
End Proc

