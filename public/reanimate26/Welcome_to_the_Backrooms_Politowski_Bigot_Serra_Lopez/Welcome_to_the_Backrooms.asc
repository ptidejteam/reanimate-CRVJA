     map(EXPL_X_P2, tmp) = 2
     tile_broken = 1
     PROC_TRY_DROP_MILK[EXPL_X_P2, tmp]
     exploding_tiles(EXPL_X_P2, tmp) = 1
    
     Y = (EXPL_Y_P2 - 1) * TILE_SIZE + 4
     Sprite 21, CX, Y, 3
  End If
  If tile_broken = 1
     PROC_DRAW_MAP
     PROC_DRAW_MILK
  End If
End Proc

Procedure PROC_CLEAR_EXPL_P1
   Sprite 3, TRASH_X, TRASH_Y, 1
  Sprite 4, TRASH_X, TRASH_Y, 1
  Sprite 5, TRASH_X, TRASH_Y, 1
  Sprite 6, TRASH_X, TRASH_Y, 1
  Sprite 7, TRASH_X, TRASH_Y, 1
  Sprite 8, TRASH_X, TRASH_Y, 1
  Sprite 9, TRASH_X, TRASH_Y, 1
  Sprite 10, TRASH_X, TRASH_Y, 1
  Sprite 11, TRASH_X, TRASH_Y, 1
  exploding_tiles(EXPL_X, EXPL_Y) = 0
  tmp = EXPL_Y - 1
  exploding_tiles(EXPL_X, tmp) = 0
  tmp = EXPL_Y - 2
  exploding_tiles(EXPL_X, tmp) = 0
  tmp = EXPL_Y + 1
  exploding_tiles(EXPL_X, tmp) = 0
  tmp = EXPL_Y + 2
  exploding_tiles(EXPL_X, tmp) = 0
  tmp = EXPL_X - 1
  exploding_tiles(tmp, EXPL_Y) = 0
  tmp = EXPL_X - 2
  exploding_tiles(tmp, EXPL_Y) = 0
  tmp = EXPL_X + 1
  exploding_tiles(tmp, EXPL_Y) = 0
  tmp = EXPL_X + 2
  exploding_tiles(tmp, EXPL_Y) = 0
  ' This means that is two bombs are exploding side to side, the second one will
  ' Some of its explosion tiles will become harmless when the first one disappears
  ' (but no one will actually find this ingame)
  If EXPL_ACTIVE_P2 = 1
     PROC_DRAW_EXPLOSION_H_P2
     PROC_DRAW_EXPLOSION_V_P2
  End If
End Proc

Procedure PROC_CLEAR_EXPL_P2
   Sprite 14, TRASH_X, TRASH_Y, 1
  Sprite 15, TRASH_X, TRASH_Y, 1
  Sprite 16, TRASH_X, TRASH_Y, 1
  Sprite 17, TRASH_X, TRASH_Y, 1
  Sprite 18, TRASH_X, TRASH_Y, 1
  Sprite 19, TRASH_X, TRASH_Y, 1
  Sprite 20, TRASH_X, TRASH_Y, 1
  Sprite 21, TRASH_X, TRASH_Y, 1
  Sprite 22, TRASH_X, TRASH_Y, 1
  exploding_tiles(EXPL_X_P2, EXPL_Y_P2) = 0
  tmp = EXPL_Y_P2 - 1
  exploding_tiles(EXPL_X_P2, tmp) = 0
  tmp = EXPL_Y_P2 - 2
  exploding_tiles(EXPL_X_P2, tmp) = 0
  tmp = EXPL_Y_P2 + 1
  exploding_tiles(EXPL_X_P2, tmp) = 0
  tmp = EXPL_Y_P2 + 2
  exploding_tiles(EXPL_X_P2, tmp) = 0
  tmp = EXPL_X_P2 - 1
  exploding_tiles(tmp, EXPL_Y_P2) = 0
  tmp = EXPL_X_P2 - 2
  exploding_tiles(tmp, EXPL_Y_P2) = 0
  tmp = EXPL_X_P2 + 1
  exploding_tiles(tmp, EXPL_Y_P2) = 0
  tmp = EXPL_X_P2 + 2
  exploding_tiles(tmp, EXPL_Y_P2) = 0
  ' This means that is two bombs are exploding side to side, the second one will
  ' Some of its explosion tiles will become harmless when the first one disappears
  ' (but no one will actually find this ingame)
  If EXPL_ACTIVE = 1
     PROC_DRAW_EXPLOSION_H
     PROC_DRAW_EXPLOSION_V
  End If

End Proc

Procedure PROC_CHECK_DAMAGE_P1
  If CURRENT_DAMAGE_COOLDOWN_P1 = 0
     damage_received = 0
     If exploding_tiles(PX, PY) = 1
        PLAYER_1_LIFE = PLAYER_1_LIFE - 1
        CURRENT_DAMAGE_COOLDOWN_P1 = DAMAGE_COOLDOWN
        damage_received = 1
        If PLAYER_1_LIFE = 0
           PLAYER_1_DIED = 1
        End If
     End If
     If damage_received = 0
        If CURRENT_MONSTERS > 0
           If PX = P_MONSTER_ONE_X
              If PY = P_MONSTER_ONE_Y
                 PLAYER_1_LIFE = PLAYER_1_LIFE - 1
                 CURRENT_DAMAGE_COOLDOWN_P1 = DAMAGE_COOLDOWN
                 damage_received = 1
              End If
           End If
        End If
     End If
     If damage_received = 0
        If CURRENT_MONSTERS > 1
           If PX = P_MONSTER_TWO_X
              If PY = P_MONSTER_TWO_Y
                 PLAYER_1_LIFE = PLAYER_1_LIFE - 1
                 CURRENT_DAMAGE_COOLDOWN_P1 = DAMAGE_COOLDOWN
              End If
           End If
        End If
     End If
     If PLAYER_1_LIFE <= 0
        PLAYER_1_LIFE = 0
        PLAYER_1_DIED = 1
     End If
  End If
End Proc

Procedure PROC_CHECK_DAMAGE_P2
  If CURRENT_DAMAGE_COOLDOWN_P2 = 0
     damage_received = 0
     If exploding_tiles(P2X, P2Y) = 1
        PLAYER_2_LIFE = PLAYER_2_LIFE - 1
        CURRENT_DAMAGE_COOLDOWN_P2 = DAMAGE_COOLDOWN
        damage_received = 1
        If PLAYER_2_LIFE = 0
           PLAYER_2_DIED = 1
        End If
     End If
     If damage_received = 0
        If CURRENT_MONSTERS > 0
           If P2X = P_MONSTER_ONE_X
              If P2Y = P_MONSTER_ONE_Y
                 PLAYER_2_LIFE = PLAYER_2_LIFE - 1
                 CURRENT_DAMAGE_COOLDOWN_P2 = DAMAGE_COOLDOWN
                 damage_received = 1
              End If
           End If
        End If
     End If
     If damage_received = 0
        If CURRENT_MONSTERS > 1
           If P2X = P_MONSTER_TWO_X
              If P2Y = P_MONSTER_TWO_Y
                 PLAYER_2_LIFE = PLAYER_2_LIFE - 1
                 CURRENT_DAMAGE_COOLDOWN_P2 = DAMAGE_COOLDOWN
              End If
           End If
        End If
     End If
     If PLAYER_2_LIFE <= 0
        PLAYER_2_LIFE = 0
        PLAYER_2_DIED = 1
     End If
  End If
End Proc
Procedure PROC_CHECK_DAMAGE_MONSTERS
  If exploding_tiles(P_MONSTER_ONE_X, P_MONSTER_ONE_Y) = 1
     MONSTER_ONE_ALIVE = 0
     P_MONSTER_ONE_X = 0
     P_MONSTER_ONE_Y = 1
     CURRENT_MONSTERS = CURRENT_MONSTERS - 1
  End If
  If exploding_tiles(P_MONSTER_TWO_X, P_MONSTER_TWO_Y) = 1
     MONSTER_TWO_ALIVE = 0
     P_MONSTER_TWO_X = 0
     P_MONSTER_TWO_Y = 1
     CURRENT_MONSTERS = CURRENT_MONSTERS - 1
  End If
End Proc
Procedure PROC_DRAW_MAP

     For x = 0 To MAP_SIZE - 1
       For y = 0 To MAP_SIZE - 1
        x13 = x * TILE_SIZE
        y13 = y * TILE_SIZE
        x23 = x13 + TILE_SIZE - 1
        y23 = y13 + TILE_SIZE - 1
        If fog(x, y) = 0
        ' Wall tiles
        If map(x, y) = 1
           If CURRENT_LEVEL < 5
              Ink 1
           End If
           If CURRENT_LEVEL >= 5
              If CURRENT_LEVEL < 10
                 Ink 6
              Else
                 Ink 4
              End If
           End If
           Bar x13, y13 To x23, y23
        End If

        ' Empty tiles
        If map(x, y) = 2
           If CURRENT_LEVEL < 5
              Ink 0
           End If
           If CURRENT_LEVEL >= 5
              If CURRENT_LEVEL < 10
                 Ink 7
              Else
                 Ink 6
              End If
           End If
           Bar x13, y13 To x23, y23
        End If
         ' Breakable walls
        If map(x, y) = 3
           Ink 2
           Bar x13, y13 To x23, y23
        End If

        ' Exit
        If map(x, y) = 4
           Ink 3
           Bar x13, y13 To x23, y23
        End If
        Else
           Ink 4
           Bar x13, y13 To x23, y23
        End If
    
     Next
  Next

End Proc

' NEW: draws only the player's current tile (ink 2)
Procedure PROC_DRAW_PLAYER

  PROC_UPDATE_FOG[PX, PY]
  x13 = PX * TILE_SIZE + 4
  y13 = PY * TILE_SIZE + 4
  x23 = x13 + TILE_SIZE - 1
  y23 = y13 + TILE_SIZE - 1
  If PLAYER_1_DIR = 1
     If PLAYER_1_ANIM = 1
        Sprite 1, x13, y13, 4
        PLAYER_1_ANIM  = 0
     Else
        Sprite 1, x13, y13, 5
        PLAYER_1_ANIM  = 1
     End If
  Else
     If PLAYER_1_ANIM = 1
        Sprite 1, x13, y13, 12
        PLAYER_1_ANIM  = 0
     Else
        Sprite 1, x13, y13, 11
        PLAYER_1_ANIM  = 1
     End If
  End If
End Proc

Procedure PROC_DRAW_PLAYER2
  PROC_UPDATE_FOG[P2X, P2Y]

  x13 = P2X * TILE_SIZE + 4
  y13 = P2Y * TILE_SIZE + 4
  x23 = x13 + TILE_SIZE - 1
  y23 = y13 + TILE_SIZE - 1
  If PLAYER_2_DIR = 1
     If PLAYER_2_ANIM = 1
        Sprite 12, x13, y13, 4
        PLAYER_2_ANIM  = 0
     Else
        Sprite 12, x13, y13, 5
        PLAYER_2_ANIM  = 1
     End If
  Else
     If PLAYER_2_ANIM = 1
        Sprite 12, x13, y13, 12
        PLAYER_2_ANIM  = 0
     Else
        Sprite 12, x13, y13, 11
        PLAYER_2_ANIM  = 1
     End If
  End If
End Proc


Procedure PROC_DRAW_MONSTERS
  x13 = P_MONSTER_ONE_X * TILE_SIZE + 4
  y13 = P_MONSTER_ONE_Y * TILE_SIZE + 4
  anim = 6
  If MONSTER_ONE_TYPE = 1
     If MONSTER_ONE_ANIMATION = 0
        anim = 7
     Else
        anim = 8
     End If
  End If
  If MONSTER_ONE_TYPE = 2
     If MONSTER_ONE_ANIMATION = 0
        anim = 9
     Else
        anim = 10
     End If
  End If
  If MONSTER_ONE_TYPE > 0
     If fog(P_MONSTER_ONE_X , P_MONSTER_ONE_Y ) = 0
        Sprite 23, x13, y13, anim
          
     Else
        Sprite 23, TRASH_X, TRASH_Y, 0
     End If
  Else 
     Sprite 23, x13, y13, anim
  End If
  If MONSTER_ONE_ALIVE = 0
        Sprite 23, TRASH_X, TRASH_Y, 0
  End If

  x13 = P_MONSTER_TWO_X * TILE_SIZE + 4
  y13 = P_MONSTER_TWO_Y * TILE_SIZE + 4
  anim = 6
  If MONSTER_TWO_TYPE = 1
     If MONSTER_TWO_ANIMATION = 0
        anim = 7
     Else
        anim = 8
     End If
  End If
  If MONSTER_TWO_TYPE = 2
     If MONSTER_TWO_ANIMATION = 0
        anim = 9
     Else
        anim = 10
     End If
  End If
  If MONSTER_TWO_TYPE > 0
     If fog(P_MONSTER_TWO_X , P_MONSTER_TWO_Y ) = 0
        Sprite 24, x13, y13, anim
          
     Else
        Sprite 24, TRASH_X, TRASH_Y, 0
     End If
  Else 
     Sprite 24, x13, y13, anim
  End If
  If MONSTER_TWO_ALIVE = 0
        Sprite 24, TRASH_X, TRASH_Y, 0
  End If
End Proc

Procedure PROC_MOVE_MONSTERS
  If MONSTER_ONE_ALIVE = 1
  If MONSTER_ONE_TIMER = 0
     MONSTER_ONE_ANIMATION = 2 - MONSTER_ONE_ANIMATION
     DX = 0 : DY = 0
     DXone = Rnd(1)
     TARGETX = 0
     TARGETY = 0
     distP1 = (P_MONSTER_ONE_X - PX) * (P_MONSTER_ONE_X - PX) + (P_MONSTER_ONE_Y - PY) * (P_MONSTER_ONE_Y - PY)
     distP2 = (P_MONSTER_ONE_X - P2X) * (P_MONSTER_ONE_X - P2X) + (P_MONSTER_ONE_Y - P2Y) * (P_MONSTER_ONE_Y - P2Y)
     If distP1 > distP2
        TARGETX = P2X
        TARGETY = P2Y
     Else
        TARGETX = PX
        TARGETY = PY
     End If
     If PLAYER_1_DIED = 1
        TARGETX = P2X
        TARGETY = P2Y
     End If
     If PLAYER_2_DIED = 1
        TARGETX = PX
        TARGETY = PY
     End If
     If TARGETX  > P_MONSTER_ONE_X
        DX = 1
     End If

     If TARGETX < P_MONSTER_ONE_X
        DX = 2
     End If

     If TARGETY > P_MONSTER_ONE_Y
        DY = 1
     End If

     If TARGETY < P_MONSTER_ONE_Y
        DY = 2
     End If

     If DX <> 0
        DY = 0
     End If

     previousOneX = P_MONSTER_ONE_X
     previousOneY = P_MONSTER_ONE_Y
     previousTwoX = P_MONSTER_TWO_X
     previousTwoY = P_MONSTER_TWO_Y
     random_movement = Rnd(3)

     If random_movement <> 0
        If DX = 1
           tx = P_MONSTER_ONE_X + 1
           ty = P_MONSTER_ONE_Y
           valid = 0
           If MONSTER_ONE_TYPE = 0
              valid = 1
           Else
              If map(tx,ty) = 2
                 valid = 1
              End If
           End If

           If valid = 1
              P_MONSTER_ONE_X = tx
              If P_MONSTER_ONE_X = P_MONSTER_TWO_X
                 If P_MONSTER_ONE_Y = P_MONSTER_TWO_Y
                    P_MONSTER_ONE_X = previousOneX
                 End If
              End If
           End If
        End If

        If DX = 2
           tx = P_MONSTER_ONE_X - 1
           ty = P_MONSTER_ONE_Y
           valid = 0
           If MONSTER_ONE_TYPE = 0
              valid = 1
           Else
              If map(tx,ty) = 2
                 valid = 1
              End If
           End If

           If valid = 1
              P_MONSTER_ONE_X = tx
              If P_MONSTER_ONE_X = P_MONSTER_TWO_X
                 If P_MONSTER_ONE_Y = P_MONSTER_TWO_Y
                    P_MONSTER_ONE_X = previousOneX
                 End If
              End If
           End If
        Else
           If DY = 1
              tx = P_MONSTER_ONE_X
              ty = P_MONSTER_ONE_Y + 1
              valid = 0
              If MONSTER_ONE_TYPE = 0
                 valid = 1
              Else
                 If map(tx,ty) = 2
                    valid = 1
                 End If
              End If

              If valid = 1
                 P_MONSTER_ONE_Y = ty
                 If P_MONSTER_ONE_X = P_MONSTER_TWO_X
                    If P_MONSTER_ONE_Y = P_MONSTER_TWO_Y
                       P_MONSTER_ONE_Y = previousOneY
                    End If
                 End If
              End If
           Else
              If DY = 2
                 tx = P_MONSTER_ONE_X
                 ty = P_MONSTER_ONE_Y - 1
                 valid = 0
                 If MONSTER_ONE_TYPE = 0
                    valid = 1
                 Else
                    If map(tx,ty) = 2
                       valid = 1
                    End If
                 End If

                 If valid = 1
                    P_MONSTER_ONE_Y = ty
                    If P_MONSTER_ONE_X = P_MONSTER_TWO_X
                       If P_MONSTER_ONE_Y = P_MONSTER_TWO_Y
                          P_MONSTER_ONE_Y = previousOneY
                       End If
                    End If
                 End If
              End If
           End If
        End If
     Else
        If DX = 1
           If DXone = 0
              tx = P_MONSTER_ONE_X
              ty = P_MONSTER_ONE_Y + 1
              If MONSTER_ONE_TYPE = 0
                 P_MONSTER_ONE_Y = ty
              Else
                 If map(tx,ty) = 2
                    P_MONSTER_ONE_Y = ty
                 End If
              End If
           Else
              tx = P_MONSTER_ONE_X
              ty = P_MONSTER_ONE_Y - 1
              If MONSTER_ONE_TYPE = 0
                 P_MONSTER_ONE_Y = ty
              Else
                 If map(tx,ty) = 2
                    P_MONSTER_ONE_Y = ty
                 End If
              End If
           End If
        End If

        If DX = 2
           tx = P_MONSTER_ONE_X
           ty = P_MONSTER_ONE_Y + 1
           If MONSTER_ONE_TYPE = 0
                 P_MONSTER_ONE_Y = ty
              Else
                 If map(tx,ty) = 2
                    P_MONSTER_ONE_Y = ty
                 End If
              End If
        Else
           tx = P_MONSTER_ONE_X
           ty = P_MONSTER_ONE_Y - 1
           If MONSTER_ONE_TYPE = 0
                 P_MONSTER_ONE_Y = ty
              Else
                 If map(tx,ty) = 2
                    P_MONSTER_ONE_Y = ty
                 End If
              End If
        End If

        If DY = 1
           If DXone = 0
              tx = P_MONSTER_ONE_X + 1
              ty = P_MONSTER_ONE_Y
              If MONSTER_ONE_TYPE = 0
                 P_MONSTER_ONE_X = tx
              Else
                 If map(tx,ty) = 2
                    P_MONSTER_ONE_X = tx
                 End If
              End If
           Else
              tx = P_MONSTER_ONE_X - 1
              ty = P_MONSTER_ONE_Y
              If MONSTER_ONE_TYPE = 0
                 P_MONSTER_ONE_X = tx
              Else
                 If map(tx,ty) = 2
                    P_MONSTER_ONE_X = tx
                 End If
              End If
           End If
        End If

        If DY = 2
           If DXone = 0
              tx = P_MONSTER_ONE_X + 1
              ty = P_MONSTER_ONE_Y
              If MONSTER_ONE_TYPE = 0
                 P_MONSTER_ONE_X = tx
              Else
                 If map(tx,ty) = 2
                    P_MONSTER_ONE_X = tx
                 End If
              End If
           Else
              tx = P_MONSTER_ONE_X - 1
              ty = P_MONSTER_ONE_Y
              If MONSTER_ONE_TYPE = 0
                 P_MONSTER_ONE_X = tx
              Else
                 If map(tx,ty) = 2
                    P_MONSTER_ONE_X = tx
                 End If
              End If
           End If
        End If
     End If

     MONSTER_ONE_TIMER = MONSTER_MOVE_DELAY
     If MONSTER_ONE_TYPE = 0
        fog(P_MONSTER_ONE_X, P_MONSTER_ONE_Y) = 1
        PROC_DRAW_MAP
     End If
  End If
  End If

  If MONSTER_TWO_ALIVE = 1
  If MONSTER_TWO_TIMER = 0
     MONSTER_TWO_ANIMATION = 2 - MONSTER_TWO_ANIMATION
     DX2 = Rnd(3) - 1 : DY2 = Rnd(3) - 1

     If DX2 = 1
        tx = P_MONSTER_TWO_X + 1
        ty = P_MONSTER_TWO_Y
        If MONSTER_TWO_TYPE = 0
           P_MONSTER_TWO_X = tx
           If P_MONSTER_TWO_X = P_MONSTER_ONE_X
              If P_MONSTER_TWO_Y = P_MONSTER_ONE_Y
                 P_MONSTER_TWO_X = previousTwoX
              End If
           End If
        Else
           If map(tx,ty) = 2
              P_MONSTER_TWO_X = tx
              If P_MONSTER_TWO_X = P_MONSTER_ONE_X
                 If P_MONSTER_TWO_Y = P_MONSTER_ONE_Y
                    P_MONSTER_TWO_X = previousTwoX
                 End If
              End If
           End If  
        End If
       
     End If

     If DX2 = 2
        tx = P_MONSTER_TWO_X - 1
        ty = P_MONSTER_TWO_Y
        If MONSTER_TWO_TYPE = 0
           P_MONSTER_TWO_X = tx
           If P_MONSTER_TWO_X = P_MONSTER_ONE_X
              If P_MONSTER_TWO_Y = P_MONSTER_ONE_Y
                 P_MONSTER_TWO_X = previousTwoX
              End If
           End If
        Else
           If map(tx,ty) = 2
              P_MONSTER_TWO_X = tx
              If P_MONSTER_TWO_X = P_MONSTER_ONE_X
                 If P_MONSTER_TWO_Y = P_MONSTER_ONE_Y
                    P_MONSTER_TWO_X = previousTwoX
                 End If
              End If
           End If  
        End If
     End If

     If DY2 = 1
        tx = P_MONSTER_TWO_X
        ty = P_MONSTER_TWO_Y + 1
        If MONSTER_TWO_TYPE = 0
           P_MONSTER_TWO_Y = ty
           If P_MONSTER_TWO_X = P_MONSTER_ONE_X
              If P_MONSTER_TWO_Y = P_MONSTER_ONE_Y
                 P_MONSTER_TWO_Y = previousTwoY
              End If
           End If
        Else
           If map(tx,ty) = 2
              P_MONSTER_TWO_Y = ty
              If P_MONSTER_TWO_X = P_MONSTER_ONE_X
                 If P_MONSTER_TWO_Y = P_MONSTER_ONE_Y
                    P_MONSTER_TWO_Y = previousTwoY
                 End If
              End If
           End If  
        End If
     End If

     If DY2 = 2
        tx = P_MONSTER_TWO_X
        ty = P_MONSTER_TWO_Y - 1
        If MONSTER_TWO_TYPE = 0
           P_MONSTER_TWO_Y = ty
           If P_MONSTER_TWO_X = P_MONSTER_ONE_X
              If P_MONSTER_TWO_Y = P_MONSTER_ONE_Y
                 P_MONSTER_TWO_Y = previousTwoY
              End If
           End If
        Else
           If map(tx,ty) = 2
              P_MONSTER_TWO_Y = ty
              If P_MONSTER_TWO_X = P_MONSTER_ONE_X
                 If P_MONSTER_TWO_Y = P_MONSTER_ONE_Y
                    P_MONSTER_TWO_Y = previousTwoY
                 End If
              End If
           End If  
        End If
     End If

     MONSTER_TWO_TIMER = MONSTER_MOVE_DELAY
     If MONSTER_TWO_TYPE = 0
        fog(P_MONSTER_TWO_X, P_MONSTER_TWO_Y) = 2
        PROC_DRAW_MAP
     End If

  End If
  End If
  If MONSTER_ONE_TIMER > 0
     MONSTER_ONE_TIMER = MONSTER_ONE_TIMER - 1
  End If
  If MONSTER_TWO_TIMER > 0
     MONSTER_TWO_TIMER = MONSTER_TWO_TIMER - 1
  End If

  PROC_DRAW_MONSTERS
End Proc

Procedure PROC_MANAGE_MONSTERS
  If CURRENT_MONSTERS < MAX_MONSTERS
     If Rnd(SPAWN_RATE) = 0
        rX = Rnd(MAP_SIZE - 1)
        rY = Rnd(MAP_SIZE - 1)
        If map(rX, rY) = 2
           If (rX - PX) * (rX - PX) >= 1
              If (rY - PY) * (rY - PY) >= 1
                 If (rY - P2Y) * (rY - P2Y) >= 1
                    If (rX - P2X) * (rX - P2X) >= 1
                       If MONSTER_ONE_ALIVE = 0
                          P_MONSTER_ONE_X = rX
                          P_MONSTER_ONE_Y = rY
                          MONSTER_ONE_ALIVE = 1
                          MONSTER_ONE_TYPE = Rnd(2)
                       Else
                          P_MONSTER_TWO_X = rX
                          P_MONSTER_TWO_Y = rY
                          MONSTER_TWO_ALIVE = 1
                          MONSTER_TWO_TYPE = Rnd(2)
                       End If
                    End If
                 End If
              End If
           End If
           CURRENT_MONSTERS = CURRENT_MONSTERS + 1
        End If
     End If
  End If
End Proc

Procedure PROC_SPAWN_MONSTERS
  MONSTER_ONE_ALIVE = 0
  MONSTER_TWO_ALIVE = 0
  CURRENT_MONSTERS = 0
  For attempt = 0 To 300
     If CURRENT_MONSTERS < MAX_MONSTERS
        PROC_MANAGE_MONSTERS
     End If
  Next
End Proc

PROC_GENERATE_MAP

Procedure PROC_CHECK_COLLISION_AND_MOVE[nx, ny]
  ' Checks if the position is collidable and moves the player if so
  If map(nx, ny) = 2
     PX = nx
     PY = ny
     PROC_UPDATE_FOG[PX, PY]
     PROC_DRAW_MAP
     PROC_DRAW_PLAYER
     PROC_DRAW_MONSTERS
  End If
  If map(nx, ny) = 4
     GAME_FINISHED = 1
  End If
End Proc

Procedure PROC_CHECK_COLLISION_AND_MOVE_P2[nx, ny]
  ' Checks if the position is collidable and moves the player if so
  If map(nx, ny) = 2
     P2X = nx
     P2Y = ny
     PROC_UPDATE_FOG[P2X, P2Y]
     PROC_DRAW_MAP
     PROC_DRAW_PLAYER2
     PROC_DRAW_MONSTERS
  End If
  If map(nx, ny) = 4
     GAME_FINISHED = 1
  End If
End Proc

Procedure PROC_GENERATE_MAP
  generateX = MAP_SIZE / 2
  generateY = MAP_SIZE / 2
  UP = 0
  DOWN = 1
  LEFT = 2
  RIGHT = 3
  For i = 0 To 300
     random_direction = Rnd(3)

     If random_direction = UP
        If generateY < MAP_SIZE - 3
           generateY = generateY + 1
           map(generateX, generateY) = 2
           generateY = generateY + 1
        End If
     End If

     If random_direction = DOWN
        If generateY > 2
           generateY = generateY - 1
           map(generateX, generateY) = 2
           generateY = generateY - 1
        End If
     End If

     If random_direction = RIGHT
        If generateX < MAP_SIZE - 3
           generateX = generateX + 1
           map(generateX, generateY) = 2
           generateX = generateX + 1
        End If
     End If

     If random_direction = LEFT
        If generateX > 2
           generateX = generateX - 1
           map(generateX, generateY) = 2
           generateX = generateX - 1
        End If
     End If
     map(generateX, generateY) = 2
  Next
  For x = 0 To MAP_SIZE - 2
     For y = 0 To MAP_SIZE - 2
       If map(x, y) = 2
          If Rnd(3) = 0
              map(x, y) = 3
          End If
       End If
     Next
  Next
  max_x = 0
  max_y = 0
  max_d = 0
  For x = 0 To MAP_SIZE - 2
     For y = 0 To MAP_SIZE - 2
        If map(x, y) = 2
          d = (x - (MAP_SIZE / 2)) * (x - (MAP_SIZE / 2)) + (y - (MAP_SIZE / 2)) * (y - (MAP_SIZE / 2))
          If d >= max_d
             If d = max_d
                If Rnd(5) = 0
                   max_d = d
                   max_x = x
                   max_y = y
                End If
             Else
                max_d = d
                max_x = x
                max_y = y
             End If   
          End If
        End If
     Next
  Next
  map(max_x, max_y) = 4
End Proc

Procedure PROC_UPDATE_BOMB_P1
  If BOMB_ACTIVE = 1
     BOMB_TIMER = BOMB_TIMER + 1
     If BOMB_TIMER >= BOMB_FUSE
        BOMB_ACTIVE = 0
        Sprite 2, TRASH_X, TRASH_Y, 1 'Moves the bomb away from the game
        BOMB_TIMER = 0
        EXPL_X = BOMB_X
        EXPL_Y = BOMB_Y
        EXPL_ACTIVE = 1
        EXPL_TIMER = 0
        PROC_DRAW_EXPLOSION_H
        PROC_DRAW_EXPLOSION_V
       
     End If

  End If

  If EXPL_ACTIVE = 1
    
     EXPL_TIMER = EXPL_TIMER + 1
     If EXPL_TIMER >= EXPL_DURATION

        EXPL_ACTIVE = 0
        EXPL_TIMER = 0
        PROC_CLEAR_EXPL_P1
     End If
  End If

End Proc

Procedure PROC_UPDATE_BOMB_P2
  If BOMB_ACTIVE_P2 = 1
     BOMB_TIMER_P2 = BOMB_TIMER_P2 + 1
     If BOMB_TIMER_P2 >= BOMB_FUSE
        BOMB_ACTIVE_P2 = 0
        Sprite 13, TRASH_X, TRASH_Y, 1 'Moves the bomb away from the game
        BOMB_TIMER_P2 = 0
        EXPL_X_P2 = BOMB_X_P2
        EXPL_Y_P2 = BOMB_Y_P2
        EXPL_ACTIVE_P2 = 1
        EXPL_TIMER_P2 = 0
        PROC_DRAW_EXPLOSION_H_P2
        PROC_DRAW_EXPLOSION_V_P2
       
     End If

  End If

  If EXPL_ACTIVE_P2 = 1
    
     EXPL_TIMER_P2 = EXPL_TIMER_P2 + 1
     If EXPL_TIMER_P2 >= EXPL_DURATION

        EXPL_ACTIVE_P2 = 0
        EXPL_TIMER_P2 = 0
        PROC_CLEAR_EXPL_P2
     End If
  End If

End Proc

Procedure PROC_HIDE_ALL_SPRITES
  Sprite 1, TRASH_X, TRASH_Y, 0
  Sprite 2, TRASH_X, TRASH_Y, 0
  Sprite 3, TRASH_X, TRASH_Y, 1
  Sprite 4, TRASH_X, TRASH_Y, 1
  Sprite 5, TRASH_X, TRASH_Y, 1
  Sprite 6, TRASH_X, TRASH_Y, 1
  Sprite 7, TRASH_X, TRASH_Y, 1
  Sprite 8, TRASH_X, TRASH_Y, 1
  Sprite 9, TRASH_X, TRASH_Y, 1
  Sprite 10, TRASH_X, TRASH_Y, 1
  Sprite 11, TRASH_X, TRASH_Y, 1
  Sprite 12, TRASH_X, TRASH_Y, 0
  Sprite 13, TRASH_X, TRASH_Y, 0
  Sprite 14, TRASH_X, TRASH_Y, 1
  Sprite 15, TRASH_X, TRASH_Y, 1
  Sprite 16, TRASH_X, TRASH_Y, 1
  Sprite 17, TRASH_X, TRASH_Y, 1
  Sprite 18, TRASH_X, TRASH_Y, 1
  Sprite 19, TRASH_X, TRASH_Y, 1
  Sprite 20, TRASH_X, TRASH_Y, 1
  Sprite 21, TRASH_X, TRASH_Y, 1
  Sprite 22, TRASH_X, TRASH_Y, 1
  Sprite 23, TRASH_X, TRASH_Y, 0
  Sprite 24, TRASH_X, TRASH_Y, 0
  Sprite 25, TRASH_X, TRASH_Y, 13
End Proc

Procedure PROC_RESET_GAME_VARIABLES
  MOVE_TIMER = 0
  MOVE_TIMER_P2 = 0

  GAME_FINISHED = 0
  CURRENT_LEVEL = 1

  SPAWN_RATE = 75
  PLAYER_1_DIED = 0
  PLAYER_2_DIED = 0
  PLAYER_1_LIFE = 3
  PLAYER_2_LIFE = 3
  PX = MAP_SIZE / 2 : PY = MAP_SIZE / 2
  P2X = MAP_SIZE / 2 : P2Y = MAP_SIZE / 2
       
  PLAYER_1_ANIM = 0
  PLAYER_1_DIR = 0

  PLAYER_2_ANIM = 0
  PLAYER_2_DIR = 0

  CURRENT_DAMAGE_COOLDOWN_P1 = 0
  CURRENT_DAMAGE_COOLDOWN_P2 = 0
 
  BOMB_X = 0 : BOMB_Y = 0 : BOMB_ACTIVE = 0
  BOMB_X_P2 = 0 : BOMB_Y_P2 = 0 : BOMB_ACTIVE_P2 = 0
  EXPL_X = 0 : EXPL_Y = 0
  EXPL_X_P2 = 0 : EXPL_Y_P2 = 0
  BOMB_TIMER = 0
  BOMB_TIMER_P2 = 0
  EXPL_TIMER = 0
  EXPL_TIMER_P2 = 0
  EXPL_ACTIVE = 0
  EXPL_ACTIVE_P2 = 0
  CURRENT_MONSTERS = 0

  MONSTER_ONE_ALIVE = 0
  MONSTER_ONE_TYPE = 0
  MONSTER_TWO_ALIVE = 0
  MONSTER_TWO_TYPE = 0
  P_MONSTER_ONE_X = 3 : P_MONSTER_ONE_Y = 3
  P_MONSTER_TWO_X = 3 : P_MONSTER_TWO_Y = 3

  MONSTER_ONE_ANIMATION = 0
  MONSTER_TWO_ANIMATION = 0

  MONSTER_ONE_TIMER = 0
  MONSTER_TWO_TIMER = 0
  MONSTER_MOVE_DELAY = 30
  MONSTER_SPAWN_TIMER = 0
  MONSTER_SPAWN_DELAY = 150

  MILK_ACTIVE = 0
  MILK_X = 0
  MILK_Y = 0

  For x = 0 To MAP_SIZE - 1
     For y = 0 To MAP_SIZE - 1
        map(x, y) = 1
        fog(x, y) = 1
        exploding_tiles(x, y) = 0
     Next
  Next
End Proc

timer = 1

Do
  ' Title screen setup
  If GAME_STATE = 0
     Cls
     SCREEN_WIDTH = MAP_SIZE * TILE_SIZE
     CENTER_X = SCREEN_WIDTH / 2
     CENTER_Y = 150
     LETTER_WIDTH = 7
    
     Ink 3
     OFFSET = 10 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y - 70, "WELCOME TO"
    
     OFFSET = 13 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y - 50, "THE BACKROOMS"
    
     Ink 1
     OFFSET = 11 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y - 20, "PRESS SPACE"
    
     Sprite 30, 150, 150, 15
     Ink 5
     OFFSET = 27 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 75, "ART, DESIGN AND PROGRAMMING"
    
     OFFSET = 15 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 95, "EVAN LE BIGOT"
    
     OFFSET = 15 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 115, "MARCO LOPEZ"
     
     OFFSET = 27 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 135, "CRVJA TRANSPILER AND INITIAL PROGRAMMING"

     OFFSET = 15 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 175, "HENRIQUE SERRA"
    
     OFFSET = 27 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 195, "EMOTIONAL SUPPORT"
    
     OFFSET = 15 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 215, "CRISTIANO POLITOWSKI"
    
     GAME_STATE = 1
  End If

  ' Waiting for player to start the game
  If GAME_STATE = 1
     If Key State($39)  ' Space
        Cls
        Wait 1
        GAME_STATE = 2

        PROC_GENERATE_MAP
        PROC_SPAWN_MONSTERS

        ' Update fog first, then draw sprites over the map
        PROC_UPDATE_FOG[PX, PY]
        PROC_UPDATE_FOG[P2X, P2Y]
        PROC_DRAW_MAP
        PROC_DRAW_PLAYER
        PROC_DRAW_PLAYER2
        PROC_DRAW_MONSTERS
        PROC_DRAW_MILK

        ' Draw UI Texts
        Ink 1
        Text 0, 415, "Player 1 Life : "
        Text 220, 416, PLAYER_1_LIFE
        Text 0, 417, "Controls WASD + E"
        Text 245, 376, "\\ 3"
        Text 0, 400, "Player 2 Life : "
        Text 220, 465, PLAYER_2_LIFE
        Text 0, 401, "Controls IJKL + O"
        Text 245, 365, "\\ 3"
        Text 0, 380, "Current level : "
        Text 220, 500, CURRENT_LEVEL
     End If
  End if

  ' Main game loop logic
  If GAME_STATE = 2
     If GAME_FINISHED = 1
        CURRENT_LEVEL = CURRENT_LEVEL + 1
       
        ' Check if players reached the final level for victory
        If CURRENT_LEVEL = 13
           GAME_STATE = 4
        Else
           MILK_ACTIVE = 0
           Sprite 25, TRASH_X, TRASH_Y, 13
           MONSTER_MOVE_DELAY = BASE_MONSTER_MOVE_DELAY - CURRENT_LEVEL * 2
           If MONSTER_MOVE_DELAY < 8
              MONSTER_MOVE_DELAY = 8
           End If
           SPAWN_RATE = BASE_SPAWN_RATE - 5 * CURRENT_LEVEL
           If SPAWN_RATE < 0
              SPAWN_RATE = 0
           End If
           CURRENT_MONSTERS = 0
           MONSTER_ONE_ALIVE = 0
           MONSTER_TWO_ALIVE = 0
           If MONSTER_MOVE_DELAY < 5
              MONSTER_MOVE_DELAY = 5
           End If
           For x = 0 To MAP_SIZE - 1
              For y = 0 To MAP_SIZE - 1
                 map(x, y) = 1
                 fog(x, y) = 1
                 exploding_tiles(x, y) = 0
              Next
           Next
           PX = MAP_SIZE / 2 : PY = MAP_SIZE / 2
           P2X = MAP_SIZE / 2 : P2Y = MAP_SIZE / 2

           PROC_GENERATE_MAP
           PROC_SPAWN_MONSTERS
           PROC_UPDATE_FOG[PX, PY]
           PROC_UPDATE_FOG[P2X, P2Y]
           PROC_DRAW_MAP
           PROC_DRAW_PLAYER
           PROC_DRAW_PLAYER2
           PROC_DRAW_MONSTERS
           PROC_DRAW_MILK
           timer = 1
           GAME_FINISHED = 0
        End If
     End If
 
     PROC_CHECK_DAMAGE_P1
     PROC_UPDATE_BOMB_P1
     PROC_CHECK_DAMAGE_P2
     PROC_UPDATE_BOMB_P2
     PROC_MANAGE_MONSTERS
     PROC_MOVE_MONSTERS

     timer = timer + 1
    
     ' Player 1 movement and bomb placement
     If PLAYER_1_DIED = 0
        If Key State($11)  ' W
        If MOVE_TIMER = 0
           PROC_CHECK_COLLISION_AND_MOVE[PX, PY - 1]
           MOVE_TIMER = MOVE_DELAY
        End If
        End If

        If Key State($1F)  ' S
        If MOVE_TIMER = 0
           PROC_CHECK_COLLISION_AND_MOVE[PX, PY + 1]
           MOVE_TIMER = MOVE_DELAY
        End If
        End If

        If Key State($1E)  ' A
        If MOVE_TIMER = 0
           PLAYER_1_DIR = 0
           PROC_CHECK_COLLISION_AND_MOVE[PX - 1, PY]
           MOVE_TIMER = MOVE_DELAY
        End If
        End If

        If Key State($20)  ' D
        If MOVE_TIMER = 0
           PLAYER_1_DIR = 1
           PROC_CHECK_COLLISION_AND_MOVE[PX + 1, PY]
           MOVE_TIMER = MOVE_DELAY
        End If
        End If

        If Key State($12)  ' E
           If BOMB_ACTIVE = 0
              BOMB_X = PX
              BOMB_Y = PY
              BOMB_ACTIVE = 1
              PROC_DRAW_BOMB_P1
           End If
        End If
     Else
        PX = 0
        PY = 0
        Sprite 1, TRASH_X, TRASH_Y, 0
     End If

     ' Player 2 movement and bomb placement
     If PLAYER_2_DIED = 0
        If Key State($17)  ' I
        If MOVE_TIMER_P2 = 0
           PROC_CHECK_COLLISION_AND_MOVE_P2[P2X, P2Y - 1]
           MOVE_TIMER_P2 = MOVE_DELAY
        End If
        End If

        If Key State($25)  ' K
        If MOVE_TIMER_P2 = 0
           PROC_CHECK_COLLISION_AND_MOVE_P2[P2X, P2Y + 1]
           MOVE_TIMER_P2 = MOVE_DELAY
        End If
        End If

        If Key State($24)  ' J
        If MOVE_TIMER_P2 = 0
           PLAYER_2_DIR = 0
           PROC_CHECK_COLLISION_AND_MOVE_P2[P2X - 1, P2Y]
           MOVE_TIMER_P2 = MOVE_DELAY
        End If
        End If

        If Key State($26)  ' L
        If MOVE_TIMER_P2 = 0
           PLAYER_2_DIR = 1
           PROC_CHECK_COLLISION_AND_MOVE_P2[P2X + 1, P2Y]
           MOVE_TIMER_P2 = MOVE_DELAY
        End If
        End If

        If Key State($18)  ' O
           If BOMB_ACTIVE_P2 = 0
              BOMB_X_P2 = P2X
              BOMB_Y_P2 = P2Y
              BOMB_ACTIVE_P2 = 1
              PROC_DRAW_BOMB_P2
           End If
        End If
     Else
        P2X = 0
        P2Y = 0
        Sprite 12, TRASH_X, TRASH_Y, 0
     End If

     PROC_CHECK_MILK
     PROC_DRAW_MILK
     PROC_CHECK_DAMAGE_MONSTERS
    
     ' Reduce timers
     If MOVE_TIMER > 0: MOVE_TIMER = MOVE_TIMER - 1 : End If
    
     If MOVE_TIMER_P2 > 0: MOVE_TIMER_P2 = MOVE_TIMER_P2 - 1 : End If
    
     If CURRENT_DAMAGE_COOLDOWN_P1 > 0: CURRENT_DAMAGE_COOLDOWN_P1 = CURRENT_DAMAGE_COOLDOWN_P1 - 1 : End If
    
     If CURRENT_DAMAGE_COOLDOWN_P2 > 0: CURRENT_DAMAGE_COOLDOWN_P2 = CURRENT_DAMAGE_COOLDOWN_P2 - 1 : End If

     ' Check if both players are dead to trigger the game over screen
     If PLAYER_1_DIED = 1
        If PLAYER_2_DIED = 1
           GAME_STATE = 3
        End If
     End If
  End If
 
  ' --- ENDING STATES ---
 
  ' Defeat Screen
  If GAME_STATE = 3

     PROC_HIDE_ALL_SPRITES

     Cls
     SCREEN_WIDTH = MAP_SIZE * TILE_SIZE
     CENTER_X = SCREEN_WIDTH / 2
     CENTER_Y = 180
     LETTER_WIDTH = 7
    
     Ink 3
     OFFSET = 9 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y - 50, "GAME OVER"
    
     OFFSET = 22 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y - 30, "BOTH PLAYERS DEFEATED!"
     Text CENTER_X - OFFSET, CENTER_Y - 10, "YOU\'VE REACHED LEVEL"
     Text CENTER_X + 140, CENTER_Y + 30, CURRENT_LEVEL

     Sprite 30, 150, 230, 16

     Ink 5
     OFFSET = 10 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 90, "NO WAY OUT"
    
     Ink 1
     OFFSET = 25 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 110, "PRESS SPACE TO PLAY AGAIN"
     MONSTER_ONE_ALIVE = 0
     MONSTER_TWO_ALIVE = 0
     GAME_STATE = 5
  End If

  ' Victory Screen
  If GAME_STATE = 4
     PROC_HIDE_ALL_SPRITES

     Cls
     SCREEN_WIDTH = MAP_SIZE * TILE_SIZE
     CENTER_X = SCREEN_WIDTH / 2
     CENTER_Y = 180
     LETTER_WIDTH = 7
    
     Ink 3
     OFFSET = 16 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y - 20, "CONGRATULATIONS!"
    
     OFFSET = 26 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y, "YOU ESCAPED THE BACKROOMS!"
    
     Sprite 30, 150, 230, 15

     Ink 5
     OFFSET = 22 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 90, "YOU ARE BOTH SAFE NOW!"
    
     Ink 1
     OFFSET = 25 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 110, "PRESS SPACE IF YOU WANT TO KEEP EXPLORING"
     MONSTER_ONE_ALIVE = 0
     MONSTER_TWO_ALIVE = 0
     GAME_STATE = 6
  End If

  ' Idle state waiting for restart
  If GAME_STATE = 5
     If Key State($39)  ' Spaces
        PROC_RESET_GAME_VARIABLES
        Cls
        Wait 1

        ' Skip States 0 and 1, go directly to game State 2 setup
        GAME_STATE = 2

        PROC_GENERATE_MAP
        PROC_SPAWN_MONSTERS

        PROC_UPDATE_FOG[PX, PY]
        PROC_UPDATE_FOG[P2X, P2Y]
        PROC_DRAW_MAP
        PROC_DRAW_PLAYER
        PROC_DRAW_PLAYER2
        PROC_DRAW_MONSTERS
        PROC_DRAW_MILK

        ' Draw UI Texts
        Ink 1
        Text 0, 415, "Player 1 Life : "
        Text 220, 416, PLAYER_1_LIFE
        Text 245, 396, "\\ 3"
        Text 0, 425, "Player 2 Life : "
        Text 220, 465, PLAYER_2_LIFE
        Text 245, 405, "\\ 3"
        Text 0, 420, "Current level : "
        Text 220, 500, CURRENT_LEVEL

        timer = 1
     End If
  End If

  If GAME_STATE = 6
     If Key State($39)  ' Spaces
        CURRENT_MONSTERS = 0
        Cls
        Wait 1

        ' Skip States 0 and 1, go directly to game State 2 setup
        GAME_STATE = 2

        PROC_GENERATE_MAP
        PROC_SPAWN_MONSTERS

        PROC_UPDATE_FOG[PX, PY]
        PROC_UPDATE_FOG[P2X, P2Y]
        PROC_DRAW_MAP
        PROC_DRAW_PLAYER
        PROC_DRAW_PLAYER2
        PROC_DRAW_MONSTERS
        PROC_DRAW_MILK

        ' Draw UI Texts
        Ink 1
        Text 0, 415, "Player 1 Life : "
        Text 220, 416, PLAYER_1_LIFE
        Text 245, 396, "\\ 3"
        Text 0, 425, "Player 2 Life : "
        Text 220, 465, PLAYER_2_LIFE
        Text 245, 405, "\\ 3"
        Text 0, 420, "Current level : "
        Text 220, 500, CURRENT_LEVEL

        timer = 1
     End If
  End If


  ' Secret Screen
  If GAME_STATE = 7
     PROC_HIDE_ALL_SPRITES

     Cls
     SCREEN_WIDTH = MAP_SIZE * TILE_SIZE
     CENTER_X = SCREEN_WIDTH / 2
     CENTER_Y = 180
     LETTER_WIDTH = 7
    
     Ink 3
     OFFSET = 15 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y - 150, "SPECIAL THANKS"
     
     Ink 1
     OFFSET = 28 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y - 50, "SPECIAL THANKS TO THE REANIMATE 2026 ORGANISERS, PARTICIPANTS AND ANYONE WHO HELPED ANIMATE THIS EVENT"
    
     OFFSET = 28 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y, "THIS EVENT WAS VERY COOL, I HAD FUN MAKING THIS GAME AND ATTENDING THE EVENT OVERALL"
     
     Sprite 31, 50, 430, 0
     Sprite 32, 70, 430, 1
     Sprite 33, 90, 430, 2
     Sprite 34, 110, 430, 3
     Sprite 35, 130, 430, 4
     Sprite 36, 150, 430, 5
     Sprite 37, 170, 430, 6
     Sprite 38, 190, 430, 7
     Sprite 39, 210, 430, 8
     Sprite 40, 230, 430, 9
     Sprite 41, 250, 430, 10
     Sprite 42, 270, 430, 11
     Sprite 43, 290, 430, 12
     Sprite 44, 310, 430, 13
     Sprite 45, 330, 430, 14
     Sprite 46, 50, 450, 15
     Sprite 47, 200, 450, 16


     OFFSET = 28 * LETTER_WIDTH
     Text CENTER_X - OFFSET, CENTER_Y + 30, "BUT ALSO SPECIAL THANKS TO YOU FOR PLAYING THIS GAME !"
     
     MONSTER_ONE_ALIVE = 0
     MONSTER_TWO_ALIVE = 0
  End If

  If Key State($14) 'T
     GAME_STATE = 7
  End If

  Wait 1
Loop

End