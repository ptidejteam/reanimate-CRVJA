     exploding_tiles(tmp, EXPL_Y_P2) = 1
    
     X = X + TILE_SIZE
     Sprite 15, X, CY, 2
  End If
  If map(EXPL_X_P2 - 1, EXPL_Y_P2) = 2
     tmp = EXPL_X_P2 - 1
     exploding_tiles(tmp, EXPL_Y_P2) = 1
     X = (EXPL_X_P2 - 1) * TILE_SIZE + 4
     Sprite 17, X, CY, 2
     If map(EXPL_X_P2 - 2, EXPL_Y_P2) > 1
        tmp = EXPL_X_P2 - 2
        If map(EXPL_X_P2 - 2, EXPL_Y_P2) = 3
           map(tmp, EXPL_Y_P2) = 2
           tile_broken = 1
           PROC_TRY_DROP_MILK[tmp, EXPL_Y_P2]
        End If
        exploding_tiles(tmp, EXPL_Y_P2) = 1
        X = X - TILE_SIZE
        Sprite 18, X, CY, 2
     End If
  End If
  If map(EXPL_X_P2 - 1, EXPL_Y_P2) = 3
     tmp = EXPL_X_P2 - 1
     map(tmp, EXPL_Y_P2) = 2
     tile_broken = 1
     PROC_TRY_DROP_MILK[tmp, EXPL_Y_P2]
     exploding_tiles(tmp, EXPL_Y_P2) = 1
    
     X = (EXPL_X_P2 - 1) * TILE_SIZE + 4
     Sprite 17, X, CY, 2
  End If
  If tile_broken = 1
     PROC_DRAW_MAP
     PROC_DRAW_MILK
  End If
End Proc

Procedure PROC_DRAW_EXPLOSION_V
  tile_broken = 0
  CX = EXPL_X * TILE_SIZE + 4
 
  Y = EXPL_Y * TILE_SIZE + 4
  ' We check if the explosion is in a wall for the closest tiles
  ' Then we check the next ones
  If map(EXPL_X, EXPL_Y + 1) = 2
     tmp = EXPL_Y + 1
     exploding_tiles(EXPL_X, tmp) = 1
     Y = Y + TILE_SIZE
     Sprite 8, CX, Y, 3
     If map(EXPL_X, EXPL_Y + 2) > 1
        tmp = EXPL_Y + 2
        If map(EXPL_X, EXPL_Y + 2) = 3
           map(EXPL_X, tmp) = 2
           tile_broken = 1
           PROC_TRY_DROP_MILK[EXPL_X, tmp]
        End If        
        exploding_tiles(EXPL_X, tmp) = 1
        Y = Y + TILE_SIZE
        Sprite 9, CX, Y, 3
     End If
  End If
  If map(EXPL_X, EXPL_Y + 1) = 3
     tmp = EXPL_Y + 1
     map(EXPL_X, tmp) = 2
     tile_broken = 1
     PROC_TRY_DROP_MILK[EXPL_X, tmp]
     exploding_tiles(EXPL_X, tmp) = 1
    
     Y = Y + TILE_SIZE
     Sprite 8, CX, Y, 3
  End If
  If map(EXPL_X, EXPL_Y - 1) = 2
     tmp = EXPL_Y - 1
     exploding_tiles(EXPL_X, tmp) = 1
     Y = (EXPL_Y - 1) * TILE_SIZE + 4
     Sprite 10, CX, Y, 3
     If map(EXPL_X, EXPL_Y - 2) > 1
        tmp = EXPL_Y - 2
        If map(EXPL_X, EXPL_Y - 2) = 3
           map(EXPL_X, tmp) = 2
           tile_broken = 1
           PROC_TRY_DROP_MILK[EXPL_X, tmp]
        End If
        exploding_tiles(EXPL_X, tmp) = 1
        Y = Y - TILE_SIZE
        Sprite 11, CX, Y, 3
     End If
  End If
  If map(EXPL_X, EXPL_Y - 1) = 3
     tmp = EXPL_Y - 1
     map(EXPL_X, tmp) = 2
     tile_broken = 1
     PROC_TRY_DROP_MILK[EXPL_X, tmp]
     exploding_tiles(EXPL_X, tmp) = 1
    
     Y = (EXPL_Y - 1) * TILE_SIZE + 4
     Sprite 10, CX, Y, 3
  End If
  If tile_broken = 1
     PROC_DRAW_MAP
     PROC_DRAW_MILK
  End If
End Proc

