' Initialize game variables
Dim MAP(MAP_HSIZE, MAP_VSIZE)
For y = 0 To MAP_VSIZE - 1
   For x = 0 To MAP_HSIZE - 1
      Read MAP(x, y)
   Next
Next

Dim POINTS_MAP_X(MAP_VSIZE)
Dim POINTS_MAP_Y(MAP_VSIZE)
Dim COLLECTED(MAP_HSIZE, MAP_VSIZE)

PACMAN_CURRENT_SPRITE = 1
PACMAN_DIRECTION = 0
PACMAN_TURN_TO_DIRECTION = 0
PACMAN_X = 14
PACMAN_Y = 23
PACMAN_DIED = 0
PACMAN_ALEADY_DIED = 0

GHOST_COUNTER = 0
GHOST_ONE_X = 12 
GHOST_ONE_Y = 13
GHOST_ONE_DIRECTION = 0
GHOST_TWO_X = 14
GHOST_TWO_Y = 15
GHOST_TIMER = 1
CURRENT_GHOST_TIMER = GHOST_TIMER

POINTS = 0
POWER_PELLET = 0
POWER_PELLET_COUNTDOWN = 0

Global MAP_HSIZE, MAP_VSIZE, PACMAN_CURRENT_SPRITE, PACMAN_DIRECTION, PACMAN_TURN_TO_DIRECTION, PACMAN_DIED, GHOST_COUNTER, TILE_SIZE, PACMAN_X, PACMAN_Y, GHOST_ONE_X, GHOST_ONE_Y, GHOST_TWO_X, GHOST_TWO_Y, POINTS, POWER_PELLET, POWER_PELLET_COUNTDOWN, GHOST_ONE_DIRECTION, PACMAN_ALEADY_DIED, GHOST_TIMER, CURRENT_GHOST_TIMER



' ==========================================
' Ghost Movement Procedure
' ==========================================
Procedure P_MOVE_GHOST_ONE
   DX = 0 : DY = 0
   DXone = Rnd(1)  ' Random movement
   
   ' Horizontal preference
   If PACMAN_X > GHOST_ONE_X
      DX = 1
   End If
   
   If PACMAN_X < GHOST_ONE_X
      DX = 2
   End If
   
   ' Vertical preference
   If PACMAN_Y > GHOST_ONE_Y
      DY = 1
   End If
   
   If PACMAN_Y < GHOST_ONE_Y
      DY = 2
   End If
   
   ' If pacman aligned horizontally, do not move vertical unless DX=0
   If DX <> 0
      DY = 0
   End If
   
   previousOneX = GHOST_ONE_X
   previousOneY = GHOST_ONE_Y
   random_movement = Rnd(3)
   
   If random_movement <> 0
      ' ============================================================
      ' Horizontal movement for Ghost 1
      ' ============================================================
      If DX = 1
         tx = GHOST_ONE_X + 1
         ty = GHOST_ONE_Y
         
         valid = 0
         If MAP(tx,ty) = 0
            valid = 1
         Else
            If MAP(tx,ty) = 3
               valid = 1
            Else
               If MAP(tx,ty) = 4
                  valid = 1
               End If
            End If
         End If
         
         If valid = 1
            GHOST_ONE_X = tx
            If GHOST_ONE_X = GHOST_TWO_X
               GHOST_ONE_X = previousOneX
            End If
         End If
      End If
      
      If DX = 2
         tx = GHOST_ONE_X - 1
         ty = GHOST_ONE_Y
         
         valid = 0
         If MAP(tx,ty) = 0
            valid = 1
         Else
            If MAP(tx,ty) = 3
               valid = 1
            Else
               If MAP(tx,ty) = 4
                  valid = 1
               End If
            End If
         End If
         
         If valid = 1
            GHOST_ONE_X = tx
            If GHOST_ONE_X = GHOST_TWO_X
               GHOST_ONE_X = previousOneX
            End If
         End If
      Else
         ' ============================================================
         ' Vertical movement for Ghost 1
         ' ============================================================
         If DY = 1
            tx = GHOST_ONE_X
            ty = GHOST_ONE_Y + 1
            
            valid = 0
            If MAP(tx,ty) = 0
               valid = 1
            Else
               If MAP(tx,ty) = 3
                  valid = 1
               Else
                  If MAP(tx,ty) = 4
                     valid = 1
                  End If
               End If
            End If
            
            If valid = 1
               GHOST_ONE_Y = ty
               If GHOST_ONE_Y = GHOST_TWO_Y
                  GHOST_ONE_Y = previousOneY
               End If
            End If
         Else
            If DY = 2
               tx = GHOST_ONE_X
               ty = GHOST_ONE_Y - 1
               
               valid = 0
               If MAP(tx,ty) = 0
                  valid = 1
               Else
                  If MAP(tx,ty) = 3
                     valid = 1
                  Else
                     If MAP(tx,ty) = 4
                        valid = 1
                     End If
                  End If
               End If
               
               If valid = 1
                  GHOST_ONE_Y = ty
                  If GHOST_ONE_Y = GHOST_TWO_Y
                     GHOST_ONE_Y = previousOneY
                  End If
               End If
            End If
         End If
      End If
   Else
      ' If pathfinding doesn't work, random movements but also check if is walkable!
      If DX = 1
         If DXone = 0
            ' Check if is walkable tile
            If MAP(GHOST_ONE_X, GHOST_ONE_Y + 1) = 0
               GHOST_ONE_Y = GHOST_ONE_Y + 1
            End If
            If MAP(GHOST_ONE_X, GHOST_ONE_Y + 1) = 2
               GHOST_ONE_Y = GHOST_ONE_Y + 1
            End If
            If MAP(GHOST_ONE_X, GHOST_ONE_Y + 1) = 3
               GHOST_ONE_Y = GHOST_ONE_Y + 1
            End If
         Else
            If MAP(GHOST_ONE_X, GHOST_ONE_Y - 1) = 0
               GHOST_ONE_Y = GHOST_ONE_Y - 1
            End If
            If MAP(GHOST_ONE_X, GHOST_ONE_Y - 1) = 2
               GHOST_ONE_Y = GHOST_ONE_Y - 1
            End If
            If MAP(GHOST_ONE_X, GHOST_ONE_Y - 1) = 3
               GHOST_ONE_Y = GHOST_ONE_Y - 1
            End If
         End If
      End If
      
      If DX = 2
         ' Check if is walkable tile
         If MAP(GHOST_ONE_X, GHOST_ONE_Y + 1) = 0
            GHOST_ONE_Y = GHOST_ONE_Y + 1
         End If
         If MAP(GHOST_ONE_X, GHOST_ONE_Y + 1) = 2
            GHOST_ONE_Y = GHOST_ONE_Y + 1
         End If
         If MAP(GHOST_ONE_X, GHOST_ONE_Y + 1) = 3
            GHOST_ONE_Y = GHOST_ONE_Y + 1
         End If
      Else
         If MAP(GHOST_ONE_X, GHOST_ONE_Y - 1) = 0
            GHOST_ONE_Y = GHOST_ONE_Y - 1
         End If
         If MAP(GHOST_ONE_X, GHOST_ONE_Y - 1) = 2
            GHOST_ONE_Y = GHOST_ONE_Y - 1
         End If
         If MAP(GHOST_ONE_X, GHOST_ONE_Y - 1) = 3
            GHOST_ONE_Y = GHOST_ONE_Y - 1
         End If
      End If
      
      If DY = 1
         If DXone = 0
            ' Check if is walkable tile
            If MAP(GHOST_ONE_X + 1, GHOST_ONE_Y) = 0
               GHOST_ONE_X = GHOST_ONE_X + 1
            End If
            
            If MAP(GHOST_ONE_X + 1, GHOST_ONE_Y) = 2
               GHOST_ONE_X = GHOST_ONE_X + 1
            End If
            
            ' Check if is walkable tile
            If MAP(GHOST_ONE_X + 1, GHOST_ONE_Y) = 3
               GHOST_ONE_X = GHOST_ONE_X + 1
            End If
         Else
            ' Check if is walkable tile
            If MAP(GHOST_ONE_X - 1, GHOST_ONE_Y) = 0
               GHOST_ONE_X = GHOST_ONE_X - 1
            End If
            
            If MAP(GHOST_ONE_X - 1, GHOST_ONE_Y) = 2
               GHOST_ONE_X = GHOST_ONE_X - 1
            End If
            
            ' Check if is walkable tile
            If MAP(GHOST_ONE_X - 1, GHOST_ONE_Y) = 3
               GHOST_ONE_X = GHOST_ONE_X - 1
            End If
         End If
      End If
      
      If DY = 2
         If DXone = 0
            If MAP(GHOST_ONE_X + 1, GHOST_ONE_Y) <> 0
               GHOST_ONE_X = GHOST_ONE_X + 1
            End If
         Else
            If MAP(GHOST_ONE_X - 1, GHOST_ONE_Y) <> 0
               GHOST_ONE_X = GHOST_ONE_X - 1
            End If
         End If
      End If
   End If
End Proc

Procedure P_MOVE_GHOST_TWO
   previousTwoX = GHOST_TWO_X
   previousTwoY = GHOST_TWO_Y

   DX2 = Rnd(3) - 1 : DY2 = Rnd(3) - 1
   
   If DX2 = 1
      If MAP(GHOST_TWO_X + 1, GHOST_TWO_Y) = 0
         GHOST_TWO_X = GHOST_TWO_X + DX2
         If GHOST_TWO_X = GHOST_ONE_X
            GHOST_TWO_X = previousTwoX
         End If
      End If
   End If
   
   If DX2 = 2
      If MAP(GHOST_TWO_X - 1, GHOST_TWO_Y) = 0
         GHOST_TWO_X = GHOST_TWO_X - 1
         If GHOST_TWO_X = GHOST_ONE_X
            GHOST_TWO_X = previousTwoX
         End If
      End If
   End If
   
   If DY2 = 1
      If MAP(GHOST_TWO_X, GHOST_TWO_Y + 1) = 0
         GHOST_TWO_Y = GHOST_TWO_Y + 1
         If GHOST_TWO_Y = GHOST_ONE_Y
            GHOST_TWO_Y = previousTwoY
         End If
      End If
   End If
   
   If DY2 = 2
      If MAP(GHOST_TWO_X, GHOST_TWO_Y - 1) = 0
         GHOST_TWO_Y = GHOST_TWO_Y - 1
         If GHOST_TWO_Y = GHOST_ONE_Y
            GHOST_TWO_Y = previousTwoY
         End If
      End If
   End If
End Proc

' ==========================================
' Map Drawing Procedure
' ==========================================
Procedure P_DRAW_MAP
	' Render MAP tiles
	For y = 0 To MAP_VSIZE - 1
		For x = 0 To MAP_HSIZE - 1
			x13 = x * TILE_SIZE
			y13 = y * TILE_SIZE
			x23 = x13 + TILE_SIZE - 1
			y23 = y13 + TILE_SIZE - 1

			' Tile type 0
			If MAP(x, y) = 0
				Ink 1
				Bar x13, y13 To x23, y23
			Else
				' Wall tiles
				If MAP(x, y) = 1
					Ink 0
					Bar x13, y13 To x23, y23
				Else
					' Small dots (value 3)
					If MAP(x,y) = 3
						Ink 1
						Bar x13, y13 To x23, y23
						If COLLECTED(x,y) = 0
							Ink 3
						End If
						Circle x * TILE_SIZE + 12, y * TILE_SIZE + 12, 2
					Else
						' Power pellets (value 4)
						If MAP(x, y) = 4
							Ink 1
							Bar x13, y13 To x23, y23
							If COLLECTED(x,y) = 0
								Ink 3
							End If
							Circle x * TILE_SIZE + 12, y * TILE_SIZE + 12, 8
						Else
							' Tile type 5
							If MAP(x, y) = 5
								Ink 1
								Bar x13, y13 To x23, y23
								If COLLECTED(x,y) = 1
									Circle x * TILE_SIZE + 12, y * TILE_SIZE + 12, 10
									Sprite 4, 500, 760, 27
								Else
									RENDER_TYPE_FIVE_X= x* TILE_SIZE + 4
									RENDER_TYPE_FIVE_Y= y* TILE_SIZE + 4
									Sprite 4, RENDER_TYPE_FIVE_X, RENDER_TYPE_FIVE_Y, 27
								End If
							Else
								' Tile type 6
								If MAP(x, y) = 6
									Ink 1
									Bar x13, y13 To x23, y23
									If COLLECTED(x,y) = 1
										Circle x * TILE_SIZE + 12, y * TILE_SIZE + 12, 10
										Sprite 5, 520, 760, 28
									Else
										RENDER_TYPE_SIX_X= x* TILE_SIZE + 4
										RENDER_TYPE_SIX_Y= y* TILE_SIZE + 4
										Sprite 5, RENDER_TYPE_SIX_X, RENDER_TYPE_SIX_Y, 28
									End If
								Else
									' Tile type 7
									If MAP(x, y) = 7
										Ink 1
										Bar x13, y13 To x23, y23
										If COLLECTED(x,y) = 1
											Circle x * TILE_SIZE + 12, y * TILE_SIZE + 12, 10
											Sprite 6, 540, 760, 29
										Else
										   RENDER_TYPE_SEVEN_X= x* TILE_SIZE + 4
										   RENDER_TYPE_SEVEN_Y= y* TILE_SIZE + 4
										   Sprite 6, RENDER_TYPE_SEVEN_X, RENDER_TYPE_SEVEN_Y, 29
										End If
									Else
										' Tile type 8
										If MAP(x, y) = 8
											Ink 1
											Bar x13, y13 To x23, y23
											If COLLECTED(x,y) = 1
												Circle x * TILE_SIZE + 12, y * TILE_SIZE + 12, 10
												Sprite 7, 560, 760, 30
											Else
												RENDER_TYPE_EIGHT_X= x* TILE_SIZE + 4
												RENDER_TYPE_EIGHT_Y= y* TILE_SIZE + 4
												Sprite 7, RENDER_TYPE_EIGHT_X, RENDER_TYPE_EIGHT_Y, 30
											End If
										End If
									End If
								End If
							End If
						End If
					End If
				End If
			End If
		Next
	Next
End Proc

' ==========================================
' Characters drawing procedure
' ==========================================
Procedure P_DRAW_CHARACTERS
	' Render Pac-Man
	pacspritex = PACMAN_X * TILE_SIZE + 4
	pacspritey = PACMAN_Y * TILE_SIZE + 4
	Sprite 1, pacspritex, pacspritey, PACMAN_CURRENT_SPRITE

	' Render Ghost 1
	ghostspriteonex = GHOST_ONE_X * TILE_SIZE + 4
	ghostspriteoney = GHOST_ONE_Y * TILE_SIZE + 4
	If POWER_PELLET > 0
		Sprite 2, ghostspriteonex, ghostspriteoney, 26 
	Else
		Sprite 2, ghostspriteonex, ghostspriteoney, 25
	End If

	' Render Ghost 2
	ghostspritetwox = GHOST_TWO_X * TILE_SIZE + 4
	ghostspritetwoy = GHOST_TWO_Y * TILE_SIZE + 4
	If POWER_PELLET > 0
		Sprite 3, ghostspritetwox, ghostspritetwoy, 26
	Else
		Sprite 3, ghostspritetwox, ghostspritetwoy, 24
	End If
End Proc

' ==========================================
' Main Game Loop
' ==========================================

Ink 3
Text  10, 750, "Power pellet!"
Text 380, 760, "Fruits:"
Text  10, 790, "Points:"
Text  10, 820, "x:"
Text 100, 820, "y:"

Do
	P_DRAW_MAP
	P_DRAW_CHARACTERS

	Ink 3
	Text 120, 790, POINTS
	Text  50, 820, PACMAN_X
	Text 140, 820, PACMAN_Y

	' Check for collision with ghosts
	' -------------------------------
	If GHOST_ONE_X = PACMAN_X
		If GHOST_ONE_Y = PACMAN_Y
			If POWER_PELLET > 0
				POINTS = POINTS + 20
				GHOST_ONE_X = 12
				GHOST_ONE_Y = 13
			Else
				PACMAN_DIED = 1
			End If
		End If
	End If

	If GHOST_TWO_X = PACMAN_X
		If GHOST_TWO_Y = PACMAN_Y
			If POWER_PELLET > 0
				POINTS = POINTS + 20
				GHOST_TWO_X = 12
				GHOST_TWO_Y = 13
			Else
				PACMAN_DIED = 1
			End If
		End If
	End If

	' Display death message
	If PACMAN_DIED = 1
		If PACMAN_ALEADY_DIED = 0
			Ink 3
			Text 380, 790, "You Died!"
			PACMAN_ALEADY_DIED = 1
			PACMAN_X = 14
			PACMAN_Y = 23
		End If
	End If

	' Manage power pellets
	' --------------------
	If POWER_PELLET > 0
		Ink 2
		Bar 3,745 To POWER_PELLET,775
		POWER_PELLET = POWER_PELLET - 5
		If POWER_PELLET < 0
			POWER_PELLET = 0
		End If
	Else
		Ink 2
		Bar 3,745 To 200,775
	End If

	' Player movement input
	' ---------------------
	NX = PACMAN_X
	NY = PACMAN_Y
	If Key State($11)  ' Up arrow
		NY = PACMAN_Y - 1
		PACMAN_DIRECTION = 2
	End If
	If Key State($1F)  ' Down arrow
		NY = PACMAN_Y + 1
		PACMAN_DIRECTION = 3
	End If
	If Key State($1E)  ' Left arrow
		NX = PACMAN_X - 1
		PACMAN_DIRECTION = 1
	End If
	If Key State($20)  ' Right arrow
		NX = PACMAN_X + 1
		PACMAN_DIRECTION = 0
	End If

	' Teleport mechanics
	If NY = 14
		If NX = -1
			If PACMAN_DIRECTION = 1
				NX = 27
			End If
		End If

		If NX = 28
			If PACMAN_DIRECTION = 0
				NX = 0
			End If
		End If
	End If

	' Move if valid
	If MAP(NX, NY) = 0
		PACMAN_X = NX
		PACMAN_Y = NY
	End If

	' Pac-Man sprite animation
	' ------------------------
	If PACMAN_DIRECTION = 0  ' Right
		PACMAN_CURRENT_SPRITE = PACMAN_CURRENT_SPRITE + 1
		If PACMAN_CURRENT_SPRITE > 5
			PACMAN_CURRENT_SPRITE = 1
		End If
	End If

	If PACMAN_DIRECTION = 1  ' Left
		PACMAN_CURRENT_SPRITE = PACMAN_CURRENT_SPRITE + 1
		If PACMAN_CURRENT_SPRITE > 11
			PACMAN_CURRENT_SPRITE = 6
		End If
	End If

	If PACMAN_DIRECTION = 2  ' Up
		PACMAN_CURRENT_SPRITE = PACMAN_CURRENT_SPRITE + 1
		If PACMAN_CURRENT_SPRITE > 17
			PACMAN_CURRENT_SPRITE = 12
		End If
	End If

	If PACMAN_DIRECTION = 3  ' Down
		PACMAN_CURRENT_SPRITE = PACMAN_CURRENT_SPRITE + 1
		If PACMAN_CURRENT_SPRITE > 23
			PACMAN_CURRENT_SPRITE = 18
		End If
	End If

	' Reset sprite when changing direction
	If PACMAN_DIRECTION = 0
		If PACMAN_DIRECTION <> PACMAN_TURN_TO_DIRECTION
			PACMAN_CURRENT_SPRITE = 1
			PACMAN_TURN_TO_DIRECTION = 0
		End If
	End If

	If PACMAN_DIRECTION = 1
		If PACMAN_DIRECTION <> PACMAN_TURN_TO_DIRECTION
			PACMAN_CURRENT_SPRITE = 6
			PACMAN_TURN_TO_DIRECTION = 1
		End If
	End If

	If PACMAN_DIRECTION = 2
		If PACMAN_DIRECTION <> PACMAN_TURN_TO_DIRECTION
			PACMAN_CURRENT_SPRITE = 11
			PACMAN_TURN_TO_DIRECTION = 2
		End If
	End If

	If PACMAN_DIRECTION = 3
		If PACMAN_DIRECTION <> PACMAN_TURN_TO_DIRECTION
			PACMAN_CURRENT_SPRITE = 17
			PACMAN_TURN_TO_DIRECTION = 3
		End If
	End If

	' Collect small dots
	' ------------------
	If MAP(NX, NY) = 3
		PACMAN_X = NX
		PACMAN_Y = NY
		If COLLECTED(PACMAN_X,PACMAN_Y) = 0
			COLLECTED(PACMAN_X,PACMAN_Y) = 1
			POINTS = POINTS + 10
		End If
	End If

	' Collect power pellets
	' ---------------------
	If MAP(NX, NY) = 4
		PACMAN_X = NX
		PACMAN_Y = NY
		If COLLECTED(PACMAN_X,PACMAN_Y) = 0
			COLLECTED(PACMAN_X,PACMAN_Y) = 1
			POINTS = POINTS + 50
			POWER_PELLET = 200
		End If
	End If

	' Collect FRUIT 5 (200 points)
	' ----------------------------
	If MAP(NX, NY) = 5
		PACMAN_X = NX
		PACMAN_Y = NY
		If COLLECTED(PACMAN_X,PACMAN_Y) = 0
			COLLECTED(PACMAN_X,PACMAN_Y) = 1
			POINTS = POINTS + 200
		End If
	End If

	' Collect FRUIT 6 (400 points)
	' ----------------------------
	If MAP(NX, NY) = 6
		PACMAN_X = NX
		PACMAN_Y = NY
		If COLLECTED(PACMAN_X,PACMAN_Y) = 0
			COLLECTED(PACMAN_X,PACMAN_Y) = 1
			POINTS = POINTS + 400
		End If
	End If

	' Collect FRUIT 7 (450 points)
	' ----------------------------
	If MAP(NX, NY) = 7
		PACMAN_X = NX
		PACMAN_Y = NY
		If COLLECTED(PACMAN_X,PACMAN_Y) = 0
			COLLECTED(PACMAN_X,PACMAN_Y) = 1
			POINTS = POINTS + 450
		End If
	End If

	' Collect FRUIT 8 (500 points)
	' ----------------------------
	If MAP(NX, NY) = 8
		PACMAN_X = NX
		PACMAN_Y = NY
		If COLLECTED(PACMAN_X,PACMAN_Y) = 0
			COLLECTED(PACMAN_X,PACMAN_Y) = 1
			POINTS = POINTS + 500
		End If
	End If

	If CURRENT_GHOST_TIMER = 0
		P_MOVE_GHOST_ONE
		P_MOVE_GHOST_TWO
		CURRENT_GHOST_TIMER = GHOST_TIMER
	Else
		CURRENT_GHOST_TIMER = CURRENT_GHOST_TIMER - 1
	End If

	Wait 6
Loop
End